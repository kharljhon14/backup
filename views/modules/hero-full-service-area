{{if {this.image} || {this.name} || {this.body} }}
<div
  class="featured-article bg-opacity-25 mb-4 position-relative rounded-5 position-relative overflow-hidden mb-15"
>
  <img
    id="hero-full-image"
    class="w-100 rounded-5 object-fit-cover"
    src="{{ this.image.getImage() }}"
    alt="Featured Article"
    fetchpriority="high"
    decoding="async"
    loading="eager"
  />
  <div
    class="image-overlay position-absolute bg-opacity-50 bg-dark top-0 start-0 w-100 h-100"
  ></div>
  <div
    class="px-6 py-8 position-absolute top-0 left-0 w-100 h-100 d-inline-flex flex-column align-items-start justify-content-md-center z-3"
  >
    <div>
      <h1 class="fs-md-3 fs-5 mb-3 text-white">
        {{ this.name }}
      </h1>
      <div class="mb-3 text-white display-2 w-lg-50 w-sm-100">
        {{ this.seo_meta_description }}
      </div>
    </div>
  </div>
</div>
{{/if}}
<script>
  function setBannerImage() {
    let bannerImage = '{{ this.image.getImage() }}';
    let bannerImg = document.querySelector("#hero-full-image");
    if(window.innerWidth <= 768) {
      bannerImage += "?width=396&height=264&crop=3:2,smart";
    } else {
      bannerImage += "?width=1400&crop=3:1,smart";
    }
    bannerImg.setAttribute('src', bannerImage)

  }
  document.addEventListener("DOMContentLoaded", function() {
    setBannerImage();
  });
</script>
<style>
  .featured-article img {
    max-height: 640px;
  }
</style>
