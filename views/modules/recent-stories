<div
  class="module mb-12"
  id="recent-stories"
  data-component-type="recent-stories"
>
  <div>
    <div class="d-flex align-items-center justify-content-between px-5">
      <h4>Recent Stories</h4>
    </div>
    <div class="col-md-12 mt-8 mb-5">
      <div class="swiper news-cards-swiper recent-news-swiper">
        <div class="swiper-wrapper"></div>
      </div>
      <div
        class="news-cards-swiper__nav d-inline-flex w-100 justify-content-end align-items-center mt-5"
      >
        <div
          class="swiper-button-prev position-relative bg-opacity-60 bg-light me-4"
          data-location-type="body:related-stories"
          data-function-type="other"
          data-format-type="icon-block"
          data-page-componentType-type="related-stories component"
          data-page-componentHeading-type="null"
          data-page-componentSubheading-type="null"
          data-page-componentIndex-type="null"
          onclick="LinkTrackingClickEvent(this,'view_content_click')"
        >
          <i class="material-symbols-outlined text-dark-100">arrow_back</i>
        </div>
        <div
          class="swiper-pagination news-cards__pagination recent-stories-pagination position-relative px-4 rounded-14"
          data-location-type="body:related-stories"
          data-function-type="other"
          data-format-type="icon-block"
          data-page-componentType-type="related-stories component"
          data-page-componentHeading-type="null"
          data-page-componentSubheading-type="null"
          data-page-componentIndex-type="null"
          onclick="LinkTrackingClickEvent(this,'view_content_click')"
        ></div>
        <div
          class="swiper-button-next position-relative bg-opacity-60 bg-light ms-4"
          data-location-type="body:related-stories"
          data-function-type="other"
          data-format-type="icon-block"
          data-page-componentType-type="related-stories component"
          data-page-componentHeading-type="null"
          data-page-componentSubheading-type="null"
          data-page-componentIndex-type="null"
          onclick="LinkTrackingClickEvent(this,'view_content_click')"
        >
          <i class="material-symbols-outlined text-dark-100">arrow_forward</i>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
        const locationModel = getCookieByName('location_model');
        const locationZuid = getCookieByName('location_zuid');

        async function getStories(params) {
          try {
            const response = await fetch(
              `https://{{instance.domain}}/stories.json?limit=0&show=15&most-recent=1`
            );
            const stories = await response.json();

            return stories.data;
          } catch (error) {
            console.error('Error in getStories:', error);
          }
        }
        async function getServiceTypes(zuid) {
          try {
            const response = await fetch(`https://{{instance.domain}}/service-types.json?zuid=${zuid}`);
            const serviceType = await response.json();
            const innerHTML = `
              <div
                class="d-flex align-items-center badge bg-white text-danger rounded-5 position-absolute top-3 start-3 px-4 py-2 z-3"
              >
                <i class="material-symbols-outlined me-2 text-primary-200 display-4">${serviceType[0].icon_name}</i>
                <span class="text-dark-100 display-4 fw-normal">${serviceType[0].title}</span>
              </div>
            `;
            return innerHTML;
          } catch (error) {
            console.error('Error in getServiceTypes:', error);
          }
        }

      function newsResolveImages() {
        let defaultImages = [];
        // populate default images
        {{ each media.{clippings.default_news_images} as media }}
        	defaultImages.push("{{ media.image.getImage() }}");
        {{ end-each }}
       return defaultImages[Math.floor(Math.random()*defaultImages.length)];
      }

        async function buildCardSlider() {
          try {
            const stories = await getStories();
            const swiperWrapper = document.querySelector('#recent-stories .swiper-wrapper');

            // Process all stories concurrently using Promise.all and map
            const processedStories = await Promise.all(
              stories.map(async (story) => {
                const serviceTypes = story.related_service
                  ? await getServiceTypes(story.related_service.meta.zuid)
                  : '';
                let imageClass = "";
                const regex = /media\.zestyio/;
                if(!regex.test(story.image)) {
                  imageClass = "object-fit-cover";
                }
                return `
                <div class="swiper-slide h-auto rounded-5">
                  <div class="card h-100 w-100 rounded-5 overflow-hidden">
                    <div class="card-img-top bg-secondary bg-opacity-25 position-relative overflow-hidden">
                      <div
                        class="position-absolute bottom-4 start-0 d-flex align-items-center justify-content-between w-100 px-6 text-light display-4 z-3"
                      >
                        <span class="d-block">${dateFormatter(story.date)}</span>
                        ${story.author ? `<span>By ${story.author}</span>` : ''}

                      </div>
                      <div class="ratio ratio-16x9 h-100">
                        <img
                          class="img-fluid ${imageClass}"
                          src="${
                            story.image
                              ? story.image
                              : newsResolveImages()
                          }"
                          alt="Stories Image"
                          style="object-fit: cover;"
                        />
                      </div>
                    </div>
                    <div class="card-body-wrapper">
                      <div class="card-body px-6 pt-6">
                        <h5 class="card-title display-2 text-start text-dark-100 fw-normal">${
                          story.title
                        }</h5>
                        <div class="card-text text-dark display-3 text-start">
                          ${story.seo_meta_description}
                        </div>
                      </div>
                      <div class="card-footer bg-transparent border-0 px-6 pb-6">
                        <a
                          href="${story.url}"
                          class="btn btn-secondary text-white w-100 d-flex align-items-center justify-content-center"
                          data-location-type="body:news-section"
                          data-function-type="navigation"
                          data-format-type="button"
                          data-link-type="internal"
                          onclick="LinkTrackingClickEvent(this,'cta_click')"
                          ><span class="material-symbols-outlined me-1 fs-7">
                          arrow_outward
                          </span>Read Article</a
                        >
                      </div>
                    </div>
                  </div>
                </div>
              `;
              })
            );

            // Join all the processed stories HTML and update the wrapper
            swiperWrapper.innerHTML = processedStories.join('');
          } catch (error) {
            console.error('Error in buildCardSlider:', error);
          }
        }
        document.addEventListener('DOMContentLoaded', function () {
          buildCardSlider();



          const newsSwiper = new Swiper('.recent-news-swiper', {
    slidesPerView: 1,
    spaceBetween: 16,
    loop: false,
    pagination: {
      type: 'custom',
      el: '.recent-stories-pagination',
      renderCustom: function (swiper, current, total) {
        const maxVisible = 5;
        let pages = [];

        if (total <= maxVisible) {
          for (let i = 1; i <= total; i++) {
            pages.push(i);
          }
        } else {
          if (current <= 2) {
            pages = [1, 2, 3, '...', total];
          } else if (current >= total - 1) {
            pages = [1, '...', total - 2, total - 1, total];
          } else {
            pages = [1, '...', current - 1, current, current + 1, '...', total];
          }
        }

        return pages
          .map((num) =>
            num === current
              ? `<span role="button" class="swiper-pagination-bullet-active swiper-pagination-bullet" data-index="${num}">${num}</span>`
              : typeof num === 'number'
              ? `<span role="button" class="clickable swiper-pagination-bullet" data-index="${num}">${num}</span>`
              : `<span class="ellipsis swiper-pagination-bullet">${num}</span>`
          )
          .join(' ');
      }
    },
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev'
    },
    breakpoints: {
      1024: { slidesPerView: 3 },
      768: { slidesPerView: 3 },
      576: { slidesPerView: 1 },
      320: { slidesPerView: 1 }
    },
    on: {
      paginationRender: function () {
        setTimeout(bindRecentPaginationClicks, 0);
      },
      slideChange: function () {
        setTimeout(bindRecentPaginationClicks, 0);
      }
    }
  });

  // Custom binding for recent news pagination
  function bindRecentPaginationClicks() {
    const bullets = document.querySelectorAll('.recent-stories-pagination .clickable');
    bullets.forEach(bullet => {
      bullet.addEventListener('click', function () {
        const index = parseInt(this.getAttribute('data-index'), 10);
        if (!isNaN(index)) {
          newsSwiper.slideTo(index - 1);
        }
      });
    });
  }

        });
</script>
