{{$location = {locations.filter({this.zuid}).zuid} }}

<div
  class="module mb-16"
  id="community-leaders"
  data-component-type="community-leaders"
>
  <div>
    <div class="d-flex align-items-center justify-content-between px-5">
      <h4 class="fw-normal mb-0">
          Leadership
      </h4>
      <a
        href="#"
        class="d-flex align-items-center text-dark-50 text-decoration-none leaders-view-leaders-link"
        data-location-type="body:community-leaders-section"
        data-function-type="text"
        data-format-type="button"
        data-link-type="internal"
        onclick="LinkTrackingClickEvent(this,'cta_click')"
        >View Leadership <span class="ms-3 material-symbols-outlined"> arrow_outward </span></a
      >
    </div>
    <div class="leaders-list col-md-12 mt-8 mb-5"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const locationModel = getCookieByName('location_model');
    let location_zuid = '';
    if (locationModel === '6-b4c9aba69c-h2nqvm') {
      location_zuid = getCookieByName('location_zuid');
    }

    async function getStaff() {
      try {
        const filteredRoles = await getFilteredStaffRoles();
        const response = await fetch(
          `https://{{instance.domain}}/staff.json?property=${location_zuid}&limit=3&model=${locationModel}`
        );
        const leaders = await response.json();
        return leaders;
      } catch (error) {
        console.error('Error in getStaff:', error);
        return [];
      }
    }

    async function getFilteredStaffRoles() {
      try {
        const response = await fetch(
          `https://{{instance.domain}}/staff_role_types.json`
        );
        const roles = await response.json();
        const roleZuids = roles.map(role => role.zuid);

        return roleZuids;
      } catch (error) {
        console.error('Error in getStaff:', error);
        return [];
      }
    }

    async function buildLeadersList() {
      const listContainer = document.querySelector('.leaders-list');
      try {
        // Wait for DOM to be ready
        if (document.readyState === 'loading') {
          await new Promise((resolve) => document.addEventListener('DOMContentLoaded', resolve));
        }

        // Wait a bit more to ensure template rendering is complete
        await new Promise((resolve) => setTimeout(resolve, 100));
        if (!listContainer) {
          console.error('Community Leaders list container not found');
          return;
        }

        const leaders = await getStaff();

        // Hide community leaders section if there is no data
        if (leaders.length === 0) {
          document.querySelector('#community-leaders').classList.add('d-none');
        } else {
          // Create cards for community leaders
          let leadersList = "<div class='row gap-sm-4 gap-lg-0 d-none d-lg-flex'>";
          let leadersListMobile = `
            <div class="swiper community-leaders-swiper d-sm-flex d-lg-none">
              <div class="swiper-wrapper">
          `;
  
          const filteredRoles = await getFilteredStaffRoles();
          const filteredLeaders = leaders.filter((leader) => {
            // Check if the leader has display_on_website = 1 OR has at least one role that exists in the filteredRoles array
            return (leader.display_on_website === 1);
          });
          for (let index = 0; index < leaders.length; index++) {
            const leader = leaders[index];

            let leaderImage = leader.portrait_image ? leader.portrait_image : 'https://8hxvw8tw.media.zestyio.com/338x190.png' ;
            if(window.innerWidth <= 768) {
              leaderImage += "?width=364&height=573&crop=4:3,smart&quality=100";
            } else {
              leaderImage += "?width=424&height=319&crop=4:3,smart&quality=100";
            }

            let imageClass = "object-fit-cover";
            const regex = /media\.zestyio/;
            // if(!regex.test(leaderImage)) {
            //   imageClass = "object-fit-cover";
              
            // }
            leadersList += `
              <div class="col-lg-4">
                <div class="card biograph-card h-100">
                  <div class="card-flip">
                    <!-- Front Side -->
                    <div class="card-front">
                      <div class="p-4 overflow-hidden rounded-4">
                        <img
                          class="card-img-top img-cover object-cover ratio ration-4x3 w-100 h-100 overflow-hidden rounded-4 ${imageClass}"
                          src="${leaderImage}"
                          alt="${leader.fullname}"
                        />
                      </div>
                      <div class="p-6 pt-2">
                        <div class="d-flex flex-column h-100 justify-content-between">
                          <div class="biograph-title mb-4">
                            <h6 class="fs-7 fw-normal">${leader.title_rank} ${leader.fullname}</h6>
                            <span class="text-dark-50">${
                              leader.job_role ? leader.job_role : 'No role yet'
                            }</span>
                          </div>
                          <div class="biograph-desc text-dark-50 text-truncate-3">
                            ${leader.about}
                          </div>
                        </div>

                        <div class="d-flex justify-content-end mt-12">
                          <button
                            class="btn btn-info btn-sm d-flex align-items-center justify-content-center gap-2 flip-trigger"
                            data-location-type="body:community-leaders-section"
                            data-function-type="other"
                            data-format-type="button"
                            data-link-type="internal"
                            onclick="LinkTrackingClickEvent(this,'cta_click')"
                          >
                            <span class="material-symbols-outlined text-light"> add </span>
                            Read more
                          </button>
                        </div>
                      </div>
                    </div>

                    <!-- Back Side -->
                    <div class="card-back">
                      <div class="px-6 pt-8 pb-8 d-flex flex-column justify-content-between h-100">
                        <div class="d-flex flex-column overflow-auto h-100" style="overflow: auto;">
                          <div class="biograph-title mb-4">
                            <h6 class="fs-7 fw-normal">${leader.title_rank} ${leader.fullname}</h6>
                            <span class="text-dark-50">${leader.job_role}</span>
                          </div>
                          <div class="biograph-desc text-dark-50">
                            ${leader.about}
                          </div>
                        </div>

                        <div class="d-flex justify-content-end mt-12">
                          <button
                            class="btn btn-info btn-sm d-flex align-items-center justify-content-center gap-2 flip-trigger"
                            data-location-type="body:community-leaders-section"
                            data-function-type="other"
                            data-format-type="button"
                            data-link-type="internal"
                            onclick="LinkTrackingClickEvent(this,'cta_click')"
                          >
                            <span class="material-symbols-outlined text-light"> remove </span>
                            Read less
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            `;
            leadersListMobile += `
              <div class="swiper-slide align-items-start">
                <div class="col-lg-4">
                  <div class="card biograph-card h-100">
                    <div class="card-flip">
                      <!-- Front Side -->
                      <div class="card-front">
                        <div class="p-4 rounded-4 overflow-hidden mb-4">
                          <img
                            class="card-img-top img-cover object-cover ratio ratio-4x3 overflow-hidden rounded-4 ${imageClass}"
                            src="${leaderImage}"
                            alt="Dummy Image"
                          />
                        </div>
                        <div class="p-4 pt-2">
                          <div class="d-flex flex-column h-100 justify-content-between text-start">
                            <div class="biograph-title mb-4">
                              <h6 class="fs-7 fw-normal">${leader.title_rank} ${leader.fullname}</h6>
                              <span class="text-dark-50">${leader.job_role}</span>
                            </div>
                            <div class="biograph-desc text-dark-50 text-truncate-3">
                              ${leader.about}
                            </div>
                          </div>

                          <div class="d-flex justify-content-end">
                            <button
                              class="btn btn-info btn-sm d-flex align-items-center justify-content-center gap-2 flip-trigger"
                              data-location-type="body:community-leaders-section"
                              data-function-type="other"
                              data-format-type="button"
                              data-link-type="internal"
                              onclick="LinkTrackingClickEvent(this,'cta_click')"
                            >
                              <span class="material-symbols-outlined text-light"> add </span>
                              Read more
                            </button>
                          </div>
                        </div>
                      </div>

                      <!-- Back Side -->
                      <div class="card-back">
                      <div class="px-6 pt-8 pb-8 d-flex flex-column justify-content-between h-100" >
                        <div class="d-flex flex-column overflow-auto h-100" style="overflow: auto;">
                            <div class="biograph-title mb-4">
                              <h6 class="fs-7 fw-normal">${leader.title_rank} ${leader.fullname}</h6>
                              <span class="text-dark-50">${leader.job_role}</span>
                            </div>
                            <div class="biograph-desc text-dark-50">
                              ${leader.about}
                            </div>
                          </div>

                          <div class="d-flex justify-content-end mt-12">
                            <button
                              class="btn btn-info btn-sm d-flex align-items-center justify-content-center gap-2 flip-trigger"
                              data-location-type="body:community-leaders-section"
                              data-function-type="other"
                              data-format-type="button"
                              data-link-type="internal"
                              onclick="LinkTrackingClickEvent(this,'cta_click')"
                            >
                              <span class="material-symbols-outlined text-light"> remove </span>
                              Read less
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            `;
          }

          leadersList += '</div>';

          leadersListMobile += `
                </div>
              </div>
          `;

          leadersList += leadersListMobile;

          leadersList += `
            <div class="community-leaders-swiper__nav d-inline-flex w-100 justify-content-end align-items-center mt-5 d-sm-flex d-lg-none">
              <div class="swiper-button-prev leaders-prev-button position-relative bg-opacity-60 bg-light me-4">
                <i
                  data-location-type="body:community-leaders"
                  data-function-type="other"
                  data-format-type="icon-block"
                  data-page-componentType-type="community-leaders component"
                  data-page-componentHeading-type=null
                  data-page-componentSubheading-type=null
                  data-page-componentIndex-type=null
                  onclick="LinkTrackingClickEvent(this,'view_content_click')"
                  class="material-symbols-outlined text-dark-100"
                  >arrow_back</i
                >
              </div>
              <div class="swiper-pagination community-leaders-pagination position-relative px-4 rounded-14"></div>
              <div class="swiper-button-next leaders-next-button position-relative bg-opacity-60 bg-light ms-4">
                <i
                  data-location-type="body:community-leaders"
                  data-function-type="other"
                  data-format-type="icon-block"
                  data-page-componentType-type="community-leaders component"
                  data-page-componentHeading-type=null
                  data-page-componentSubheading-type=null
                  data-page-componentIndex-type=null
                  onclick="LinkTrackingClickEvent(this,'view_content_click')"
                  class="material-symbols-outlined text-dark-100"
                  >arrow_forward</i
                >
              </div>
            </div>
          `;

          listContainer.innerHTML = leadersList;
        }
      } catch (error) {
        console.error('Error in buildLeadersList:', error);
        if (listContainer) {
          listContainer.innerHTML = `
              <div class="text-center w-100 py-5">
                  <span class="material-symbols-outlined text-danger mb-3" style="font-size: 3rem;">error</span>
                  <p class="text-danger mb-0">Error loading community leaders. Please try again later.</p>
              </div>
          `;
        }
      }
    }

    buildLeadersList().then(() => {
      const flipButtons = document.querySelectorAll('.flip-trigger');
      for (let index = 0; index < flipButtons.length; index++) {
        flipButtons[index].addEventListener('click', function (event) {
          event.preventDefault();
          event.stopPropagation();

          const card = this.closest('.biograph-card');
          if (!card) return;

          card.classList.toggle('flipped');
        });
      }
      const s = new Swiper('.community-leaders-swiper', {
        spaceBetween: 20,
        pagination: {
          el: '.community-leaders-swiper__nav .swiper-pagination',
          clickable: true
        },
        navigation: {
          nextEl: '.leaders-next-button',
          prevEl: '.leaders-prev-button'
        },
        breakpoints: {
          1024: {
            slidesPerView: 2
          },
          768: {
            slidesPerView: 2
          },
          576: {
            slidesPerView: 1
          },
          320: {
            slidesPerView: 1
          }
        }
      });
    });
  });
  const leadersLink = document.querySelector(".leaders-view-leaders-link")
  leadersLink.setAttribute('href', cookieManager.get('location_home_url') + 'leadership');
</script>
