// Function to update distance
function updateDistance() {
  const distanceContainer = document.querySelector('.current-card__distance');
  if (distanceContainer && window.currentSearchLocation?.lat && window.currentSearchLocation?.lng) {
    const distance = window.calculateDistance(
      window.currentSearchLocation.lat,
      window.currentSearchLocation.lng,
      window.currentLocation?.latitude,
      window.currentLocation?.longitude
    ).toFixed(1);
    distanceContainer.innerHTML = `${distance} miles away from your general location`;
  }
}

// Function to initialize and watch for changes
function initializeLocationWatcher() {
  // Try to update immediately if data is available
  if (window.currentSearchLocation?.lat && window.currentSearchLocation?.lng) {
    updateDistance();
  }

  // Set up watcher for future changes
  let previousLat = window.currentSearchLocation?.lat;
  let previousLng = window.currentSearchLocation?.lng;
  
  setInterval(() => {
    if (!window.currentSearchLocation) return;
    
    if (previousLat !== window.currentSearchLocation.lat || 
        previousLng !== window.currentSearchLocation.lng) {
      previousLat = window.currentSearchLocation.lat;
      previousLng = window.currentSearchLocation.lng;
      updateDistance();
    }
  }, 100);
}
// Function to handle pin click
function handlePinClick(locationId) {
  // Find the index of the location in allFilteredLocations
  const locationIndex = allFilteredLocations.findIndex(loc => loc.zuid === locationId);
  
  if (locationIndex === -1) return;

  // Calculate which page this location should be on
  const targetPage = Math.floor(locationIndex / itemsPerPage) + 1;

  // If we're not on the correct page, update currentPage and redisplay
  if (currentPage !== targetPage) {
    currentPage = targetPage;
    displayLocations(allFilteredLocations);
  }

  // Remove selected-pin class from all cards
  document.querySelectorAll('.location-card').forEach(card => {
    card.classList.remove('selected-pin');
    card.querySelector('.pin-icon').style.display = 'none';
  });

  // After a short delay to allow for page transition
  setTimeout(() => {
    // Find and highlight the associated card
    const selectedCard = document.querySelector(`.location-card[data-location-id="${locationId}"]`);
    if (selectedCard) {
      selectedCard.classList.add('selected-pin');
      const pinIcon = selectedCard.querySelector('.pin-icon');
      if (pinIcon) {
        pinIcon.style.display = 'block';
      }
      // Scroll the card into view with smooth behavior
      selectedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, 100);
}

