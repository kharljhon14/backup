                border-bottom: none;
              }
              .autocomplete-item-location:hover {
                background-color: #f9fafb;
              }
              .autocomplete-item-location:active {
                background-color: #f3f4f6;
              }
              .autocomplete-icon-location {
                width: 18px;
                height: 18px;
                color: #6b7280;
                flex-shrink: 0;
              }
              .autocomplete-text-location {
                color: #1f2937;
                font-size: 14px;
                line-height: 1.5;
              }
            `;
            document.head.appendChild(style);
          }

          input.parentNode.style.position = 'relative';
          input.parentNode.appendChild(autocompleteContainer);

          input.addEventListener('input', function() {
            const value = this.value;

            clearTimeout(debounceTimer);

            if (value.length < 3) {
              autocompleteContainer.style.display = 'none';
              return;
            }

            // Debounce API call - only fire after user stops typing
            debounceTimer = setTimeout(() => {
              autocompleteService.getPlacePredictions({
                input: value,
                types: ['(regions)'],  // Regions type for city/ZIP searches (cheaper than geocode)
                componentRestrictions: { country: 'US' },
                sessionToken: sessionToken
              }, (predictions, status) => {
                if (status === google.maps.places.PlacesServiceStatus.OK && predictions) {
                  autocompleteContainer.innerHTML = '';
                  autocompleteContainer.style.display = 'block';

                  predictions.forEach(prediction => {
                    const item = document.createElement('div');
                    item.className = 'autocomplete-item-location';
                    item.innerHTML = `
                      <svg class="autocomplete-icon-location" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <span class="autocomplete-text-location">${prediction.description}</span>
                    `;

                    item.addEventListener('click', function() {
                      input.value = prediction.description;
                      autocompleteContainer.style.display = 'none';
                      debouncedSearchServices();

                      // Create new session token for next search
                      sessionToken = new google.maps.places.AutocompleteSessionToken();
                    });
                    autocompleteContainer.appendChild(item);
                  });
                } else {
                  autocompleteContainer.style.display = 'none';
                }
              });
            }, debounceDelay);
          });

          // Hide dropdown when clicking outside
          document.addEventListener('click', function(e) {
            if (e.target !== input && !autocompleteContainer.contains(e.target)) {
              autocompleteContainer.style.display = 'none';
            }
          });
        }

        if (inputMobile) {
          // Create session token to group autocomplete requests (reduces API costs)
          let sessionTokenMobile = new google.maps.places.AutocompleteSessionToken();
          const autocompleteServiceMobile = new google.maps.places.AutocompleteService();

          let debounceTimerMobile;
          const debounceDelayMobile = 300; // Wait 300ms after user stops typing

          // Create autocomplete dropdown container with enhanced styling
          const autocompleteContainerMobile = document.createElement('div');
          autocompleteContainerMobile.className = 'autocomplete-dropdown-container-mobile';
          autocompleteContainerMobile.style.cssText = `
            position: absolute;
            z-index: 1050;
            background: white;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            max-height: 280px;
            overflow-y: auto;
            display: none;
            width: 100%;
            margin-top: 4px;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
          `;

          // Add custom styles for mobile dropdown
          if (!document.getElementById('autocomplete-styles-location-finder-mobile')) {
            const styleMobile = document.createElement('style');
            styleMobile.id = 'autocomplete-styles-location-finder-mobile';
            styleMobile.textContent = `
              .autocomplete-dropdown-container-mobile::-webkit-scrollbar {
                width: 8px;
              }
              .autocomplete-dropdown-container-mobile::-webkit-scrollbar-track {
                background: #f1f1f1;
                border-radius: 4px;
              }
              .autocomplete-dropdown-container-mobile::-webkit-scrollbar-thumb {
                background: #c1c1c1;
                border-radius: 4px;
              }
              .autocomplete-dropdown-container-mobile::-webkit-scrollbar-thumb:hover {
                background: #a8a8a8;
              }
              .autocomplete-item-location-mobile {
                padding: 12px 16px;
                cursor: pointer;
                border-bottom: 1px solid #f3f4f6;
                transition: background-color 0.15s ease;
                display: flex;
                align-items: center;
                gap: 10px;
              }
              .autocomplete-item-location-mobile:last-child {
                border-bottom: none;
              }
              .autocomplete-item-location-mobile:hover {
                background-color: #f9fafb;
              }
              .autocomplete-item-location-mobile:active {
                background-color: #f3f4f6;
              }
              .autocomplete-icon-location-mobile {
                width: 18px;
                height: 18px;
                color: #6b7280;
                flex-shrink: 0;
              }
              .autocomplete-text-location-mobile {
                color: #1f2937;
                font-size: 14px;
                line-height: 1.5;
              }
            `;
            document.head.appendChild(styleMobile);
          }

          inputMobile.parentNode.style.position = 'relative';
          inputMobile.parentNode.appendChild(autocompleteContainerMobile);

          inputMobile.addEventListener('input', function() {
            const value = this.value;

            clearTimeout(debounceTimerMobile);

            if (value.length < 3) {
              autocompleteContainerMobile.style.display = 'none';
              return;
            }

            // Debounce API call - only fire after user stops typing
            debounceTimerMobile = setTimeout(() => {
              autocompleteServiceMobile.getPlacePredictions({
                input: value,
                types: ['(regions)'],  // Regions type for city/ZIP searches (cheaper than geocode)
                componentRestrictions: { country: 'US' },
                sessionToken: sessionTokenMobile
              }, (predictions, status) => {
                if (status === google.maps.places.PlacesServiceStatus.OK && predictions) {
                  autocompleteContainerMobile.innerHTML = '';
                  autocompleteContainerMobile.style.display = 'block';

                  predictions.forEach(prediction => {
                    const item = document.createElement('div');
                    item.className = 'autocomplete-item-location-mobile';
                    item.innerHTML = `
                      <svg class="autocomplete-icon-location-mobile" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                      <span class="autocomplete-text-location-mobile">${prediction.description}</span>
                    `;

                    item.addEventListener('click', async function() {
                      inputMobile.value = prediction.description;
                      autocompleteContainerMobile.style.display = 'none';
                      await updateMapPosition(prediction.description);

                      // Create new session token for next search
                      sessionTokenMobile = new google.maps.places.AutocompleteSessionToken();
                    });
                    autocompleteContainerMobile.appendChild(item);
                  });
                } else {
                  autocompleteContainerMobile.style.display = 'none';
                }
              });
            }, debounceDelayMobile);
          });

          // Hide dropdown when clicking outside
          document.addEventListener('click', function(e) {
            if (e.target !== inputMobile && !autocompleteContainerMobile.contains(e.target)) {
              autocompleteContainerMobile.style.display = 'none';
            }
          });
        }
        
        checkboxesItems.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                if (input.value != '') {
                    // console.log("Input Value:", input.value);
                    // searchServices();
                    debouncedSearchServices();
                } else if(input.value == '' && checkbox.checked) {
                  const city = cookieManager.get(cookieKeys.locationCity);
                  const state = cookieManager.get(cookieKeys.locationState);
                  const address = cookieManager.get(cookieKeys.locationAddress);
                  let completeAddress = '';
                  if (address === null && state === null && city === null) {
                    completeAddress = "615 Slaters Lane, Alexandria, Virginia 22314"
                  } else {
                    completeAddress = `${address}, ${city}, ${state}`;
                  }
                  input.value = completeAddress;
                  // searchServices();
                  debouncedSearchServices();
                }
            });
        });

        // Prevent Google Maps from handling the enter key
        input?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') e.preventDefault();
        });
        
        inputMobile?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') e.preventDefault();
        });

        

      }
      // Handle URL parameters
      const address = '{{request.queryParam(address)}}';
      const services = '{{request.queryParam(services)}}';
      
      
      if (address || services) {
        let hasParams = false;
        
        // Apply address parameter
        if (address && addressInput) {
          const decodedAddress = decodeURIComponent(address);
          addressInput.value = decodedAddress;
          hasParams = true;
        }

        // Apply services parameter
        if (services) {
          const addressInput = document.querySelector('#location-finder__input');
          const servicesList = decodeURIComponent(services).split(',').map(s => s.trim().toLowerCase());
          const checkboxes = document.querySelectorAll('input[type="checkbox"]');
          let servicesApplied = false;
          
          checkboxes.forEach(checkbox => {
            if (servicesList.includes(checkbox.value.toLowerCase())) {
              checkbox.checked = true;
              checkbox.setAttribute('checked', 'checked');
              servicesApplied = true;
            }
          });

          console.log(checkboxes, servicesList)

          // Update dropdown text if services were applied
          if (servicesApplied) {
            const dropdownToggle = document.querySelector('#servicesDropdown2');
            if (dropdownToggle) {
              const selectedCheckboxes = document.querySelectorAll('.location-finder .services-list--mobile input[type="checkbox"]:checked');
              if (selectedCheckboxes.length > 0) {
                const firstCheckbox = selectedCheckboxes[0];
                const firstLabel = firstCheckbox.getAttribute('data-search-term-type').trim();
                if (selectedCheckboxes.length === 1) {
                  dropdownToggle.innerHTML = `<div class="selected-pills py-3 px-1"><span class="bg-secondary-200 text-light rounded-9 px-6 py-3">${firstLabel}</span></div>`;
                } else {
                  dropdownToggle.innerHTML = `<div class="selected-pills py-3 px-1"><span class="bg-secondary-200 text-light rounded-9 px-6 py-3">${firstLabel}</span> +${selectedCheckboxes.length - 1}</div>`;
                }
              }
            }
            hasParams = true;
          }


          const city = cookieManager.get(cookieKeys.locationCity);
          const state = cookieManager.get(cookieKeys.locationState);
          const address = cookieManager.get(cookieKeys.locationAddress);

          if (address === null && state === null && city === null) {
            addressInput.setAttribute('value', '615 Slaters Lane, Alexandria, Virginia 22314');
          }else{
            const regex = /\b(?!\b(?:a|an|the|and|but|or|nor|for|so|yet|as|at|by|in|of|off|on|per|to|up|from|into|onto|over|with)\b)([A-Za-z0-9\u00C0-\u017F]+(?:['-][A-Za-z0-9\u00C0-\u017F]+)*)\b/gi;

            const result = `${address}, ${city}, ${state}`.replace(regex, (word) => {
              return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
            });
            addressInput.setAttribute("value", result)
          }
        }

        // If we have an address parameter, update the map position
        if (address && addressInput) {
          await updateMapPosition(addressInput.value);
        }

        // searchServices();
        debouncedSearchServices();
      }
      searchBtn.removeAttribute('disabled');
    }
    await initLoad();
  } catch (error) {
    console.error('Error during initialization:', error);
  }
}

// Make initLocationFinder available globally for the callback
window.initLocationFinder = initLocationFinder;

// Wait for DOM content to be loaded
document.addEventListener('DOMContentLoaded', function() {
  // The map.js file will call initLocationFinder after Google Maps is loaded
  if (window.google && window.google.maps) {
    initLocationFinder();
  }
});

</script>
