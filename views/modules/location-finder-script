<script type="text/javascript">
window.serviceTypesCache = null;
window.serviceTypesPromise = null;
window.servicesByLocationCache = new Map();
window.servicesByLocationPromise = new Map();

function getCookieByName(name) {
  const cookies = document.cookie.split(';');
  for (let cookie of cookies) {
    cookie = cookie.trim();
    if (cookie.startsWith(name + '=')) {
      const value = cookie.substring(name.length + 1);
      return decodeURIComponent(value); 
    }
  }
  return null;
}
async function getProperty() {
  try {
    const zuid = getCookieByName('location_zuid')
    const response = await fetch(`${window.location.origin}/location-finder.json?query=${zuid}`);
    const data = await response.json();
    return data.address || null;
  } catch (error) {
    // console.error('Error fetching property:', error);
    return null;
  }
}

async function getLocation(zuid) {
  try {
    const response = await fetch(`${window.location.origin}/location-finder.json?query=${zuid}`);
    if (!response.ok) {
      throw new Error('Network response was not ok');
    }
    const data = await response.json();
    return data;
  } catch (error) {
    console.error('Error checking location:', error);
    return false;
  }
}

async function getServiceAreasByState(state, services) {
  try {
    const response = await fetch(`${window.location.origin}/service-areas.json?query=${state}&services=${services}`);
    if (!response.ok) {
      throw new Error('Network response was not ok');
    }
    const data = await response.json();
    return data;
  } catch (error) {
    console.error('Error checking location:', error);
    return false;
  }
}
// Make fetchServicesForLocation available globally
window.fetchServicesForLocation = async function(zuid) {
  try {
    if (!zuid) return [];
    if (window.servicesByLocationCache.has(zuid)) {
      return window.servicesByLocationCache.get(zuid);
    }
    if (window.servicesByLocationPromise.has(zuid)) {
      return window.servicesByLocationPromise.get(zuid);
    }

    const fetchPromise = (async () => {
    const response = await fetch(`${window.location.origin}/services.json?location=${zuid}`);
    if (!response.ok) {
        throw new Error('Network response was not ok');
    }
    const data = await response.json();
    window.servicesByLocationCache.set(zuid, data);
    return data;
    })();

    window.servicesByLocationPromise.set(zuid, fetchPromise);
    const result = await fetchPromise;
    window.servicesByLocationPromise.delete(zuid);
    return result;
  } catch (error) {
    console.error('Error checking location:', error);
    window.servicesByLocationPromise.delete(zuid);
    return [];
  }
};

function setServicesLoadingState(index, message) {
  const servicesContainer = document.getElementById(`services-container-${index}`);
  if (!servicesContainer) return;
  servicesContainer.innerHTML = `
    <div class="col-12 services-loading">
      <div class="d-flex align-items-center">
        <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <span class="display-4 display-md-1">${message || 'Loading services...'}</span>
      </div>
    </div>
  `;
}

function renderServicesForLocation(loc, services, index) {
  const servicesContainer = document.getElementById(`services-container-${index}`);
  if (!servicesContainer) return;

  if (!services || services.length === 0 || !Array.isArray(services)) {
    servicesContainer.innerHTML = '<div class="col">No services available</div>';
    return;
  }

  const serviceTypes = (loc.service_types || '')
    .split(',')
    .map(s => s.trim())
    .filter(Boolean);
  const serviceTypeSet = new Set(serviceTypes);

  const servicesInnerHTML = [];
  services.forEach(service => {
    const serviceTypeZuid = service.service_type?.data?.[0]?.meta?.zuid;
    if (!serviceTypeZuid || !serviceTypeSet.has(serviceTypeZuid)) return;

    const iconName = service.service_type?.data?.[0]?.icon_name || '';
    const title = loc.redirect_url
      ? service.title
      : service.title?.replace(/<\/?b>/g, '');
    if (!title) return;

    servicesInnerHTML.push(`<div class="col">
        <div class="d-flex align-items-start">
          <span class="material-symbols-outlined text-primary-200 display-6">${iconName}</span>
          <a
            href="${service.meta?.web?.url || '#'}"
            class="display-4 text-dark-100 display-md-1 ms-2"
            data-location-type="body:location-finder"
            data-function-type="other"
            data-format-type="button"
            data-link-type="internal"
            onclick="LinkTrackingClickEvent(this,'cta_click')"
          >${title}</a>
        </div>
      </div>
    `);
  });

  servicesContainer.innerHTML = servicesInnerHTML.length > 0
    ? servicesInnerHTML.join('')
    : '<div class="col">No services available</div>';
}

// Update getServicesForServiceArea to use the cached data
async function getServicesForServiceArea(serviceArea) {
  try {
    
    // Filter services based on service area's service_types
    const areaServices = [];
    if (serviceArea.service_type && window.allServices) {
      const serviceTypes = serviceArea.service_type.data;
      
      // Use a Set for faster lookups
      const serviceTypeSet = new Set(serviceTypes);
      const serviceTypeMap = new Map(
        [...serviceTypeSet].map(serviceType => [serviceType.meta.zuid, serviceType])
      );
      // Filter the services
      for (const service of window.allServices) {
        if (serviceTypeMap.has(service.meta.zuid)) {
          areaServices.push(service);
        }
      }
    }
    
    return areaServices;
  } catch (error) {
    console.error('Error getting services for service area:', error);
    return [];
  }
}


// Pagination state
let currentPage = 1;
const itemsPerPage = 6;
let allFilteredLocations = [];

function handleApplyServices() {
  const selectedCheckboxes = document.querySelectorAll('.services-list--mobile input[type="checkbox"]:checked');
  const dropdownToggle = document.querySelector('#servicesDropdown2');
  
  // Get the current search term
  const searchInput = document.getElementById('location-finder__input');
  const searchInputMobile = document.getElementById('pac-input-mobile');
  const activeInput = searchInput;
  const searchTerm = activeInput?.value || '';

  // Get filter information
  const filterTypes = [];
  const filterValues = [];
  selectedCheckboxes.forEach(checkbox => {
      const serviceName = checkbox.getAttribute('data-search-term-type').trim();
      if (serviceName) {
          filterTypes.push(serviceName);
          filterValues.push(checkbox.value);
      }
  });
  if (selectedCheckboxes.length > 0) {
    // Get the first selected checkbox's label text
    const firstCheckbox = selectedCheckboxes[0];
    const firstLabel = firstCheckbox.closest('.service-item').querySelector('.service-name').textContent.trim();
    
    // Update dropdown button text
    if (selectedCheckboxes.length === 1) {
      dropdownToggle.innerHTML = `<div class="selected-pills py-3 px-1"><span class="bg-secondary-200 text-light rounded-9 px-6 py-3">${firstLabel}</span></div>`;
    } else {
      dropdownToggle.innerHTML = `<div class="selected-pills py-3 px-1"><span class="bg-secondary-200 text-light rounded-9 px-6 py-3">${firstLabel}</span> +${selectedCheckboxes.length - 1}</div>`;
    }

    // Track filter application
    LocationTrackingFilterEvent(
        searchTerm,
        allFilteredLocations?.length || 0,
        'location search - body',
        'autofilled filters',
        filterTypes.join(', '),
        filterValues.join(', ')
    );
  } else {
    // Reset to default text if no checkboxes selected
    dropdownToggle.innerHTML = '<span class="rounded-9 px-6 py-3">Services</span>';
  }
  
  // Trigger a new search when services are applied
  const addressInput = document.getElementById('location-finder__input');
  if (addressInput && addressInput.value) {
    // searchServices();
    debouncedSearchServices();
  }
}

function handleResetServices(checkbox) {
  const isMobile = window.innerWidth < 768;
  const locationFinderDropdown = document.querySelector("#servicesDropdown2");

  // Clear checkboxes based on view
  const checkboxes = document.querySelectorAll(isMobile ? 
    '.services-list--mobile input[type="checkbox"]' : 
    '.services-list:not(.services-list--mobile) input[type="checkbox"]'
  );
  const checkedServices = [];
  checkboxes.forEach(cb => {
    if (checkbox.value == cb.value) {
      cb.checked = false;
    }

    if (cb.checked) {
      checkedServices.push(cb.getAttribute('data-search-term-type'));
    }
  });
  

  if (checkedServices.length == 0) {
    // Reset dropdown button text
    const dropdownToggle = document.querySelector('#servicesDropdown2');
    if (dropdownToggle) {
      dropdownToggle.innerHTML = '<span class="rounded-9 px-6 py-3">Services</span>';
    }
  } else {
    if (checkedServices.length === 1) locationFinderDropdown.innerHTML =  `<div class="selected-pills py-3 px-1"><span class="bg-secondary-200 text-light rounded-9 px-6 py-3">${checkedServices[0]}</span></div>`;
    if (checkedServices.length > 1) locationFinderDropdown.innerHTML = `<div class="selected-pills py-3 px-1"><span class="bg-secondary-200 text-light rounded-9 px-6 py-3">${checkedServices[0]}</span> +${checkedServices.length - 1}</div>`;
  }

  // Track filter reset
  const searchInput = document.getElementById('location-finder__input');
  const searchInputMobile = document.getElementById('pac-input-mobile');
  const activeInput = searchInput;
  const searchTerm = activeInput?.value || '';

  LocationTrackingFilterEvent(
      searchTerm,
      allFilteredLocations?.length || 0,
      'location search - body',
      'user-entered',
      '',  // No filter type when resetting
      ''   // No filter value when resetting
  );
  
  // Trigger a new search when services are reset
  const addressInput = document.getElementById('location-finder__input');
  if (addressInput && addressInput.value) {
    // searchServices();
    debouncedSearchServices();
  }
}

function getPaginatedData(locations, page, perPage) {
  const startIndex = (page - 1) * perPage;
  const endIndex = startIndex + perPage;
  return locations.slice(startIndex, endIndex);
}

function renderPaginationControls(totalItems) {
  const totalPages = Math.ceil(totalItems / itemsPerPage);
  const paginationContainer = document.createElement('div');
  paginationContainer.className = 'pagination d-flex justify-content-center align-items-center gap-3 mt-4';
  
  const prevButton = document.createElement('button');
  prevButton.className = 'btn btn-secondary';
  prevButton.innerHTML = '&laquo; Previous';
  prevButton.disabled = currentPage === 1;
  prevButton.onclick = () => {
    if (currentPage > 1) {
      currentPage--;
      displayLocations(allFilteredLocations);
    }
  };
  
  const pageIndicator = document.createElement('span');
  pageIndicator.className = 'display-4 text-dark';
  pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;
  
  const nextButton = document.createElement('button');
  nextButton.className = 'btn btn-secondary';
  nextButton.innerHTML = 'Next &raquo;';
  nextButton.disabled = currentPage >= totalPages;
  nextButton.onclick = () => {
    if (currentPage < totalPages) {
      currentPage++;
      displayLocations(allFilteredLocations);
    }
  };
  
  paginationContainer.appendChild(prevButton);
  paginationContainer.appendChild(pageIndicator);
  paginationContainer.appendChild(nextButton);
  
  return paginationContainer;
}

function showLoadingIndicator() {
  const resultsContainer = document.querySelector('.location-results__list');
  if (!resultsContainer) return;
  
  resultsContainer.innerHTML = `
    <div class="col-12 text-center py-5">
      <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
        <span class="visually-hidden">Loading...</span>
      </div>
      <p class="mt-3 display-4">Loading location data...</p>
    </div>
  `;
}

let _displayGen = 0;

async function displayLocations(locations, selectedServices) {
  const resultsContainer = document.querySelector('.location-results__list');
  if (!resultsContainer) return;
  // Results found — clear both no-results containers
  document.querySelector('#no-service-area-container').innerHTML = '';
  document.querySelector('#no-results-container').innerHTML = '';
  const _gen = ++_displayGen;

  resultsContainer.innerHTML = '';

  if (locations.length === 0) {
    const address = document.getElementById('location-finder__input').value;
    const { county, stateCode } = await window.getCountyFromAddress(address);
    // Show loader while fetching service areas
    document.querySelector('#no-results-container').innerHTML = '';
    document.querySelector('#no-service-area-container').innerHTML = `
      <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm text-primary-200" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
      </div>
    `;
    
    // Pre-fetch service types in the background to ensure they're cached
    getServiceTypes().catch(err => console.error('Failed to preload service types:', err));
    
    // Use IIFE to avoid long promise chains
    (async function() {
      try {
        // Get county/state information
        if (!stateCode) {
          document.querySelector('#no-results-container').innerHTML = `
            <div class="col-12">
              <div class="alert alert-info">
                No locations found within 50 miles of your search location in ${county || ''}, ${stateCode}.
              </div>
            </div>
          `;
          return;
        }
        // Start fetching service areas
        const serviceAreasPromise = getServiceAreasByState(stateCode, selectedServices);

        
        // Wait for both the API response and the minimum 1s display of the loader
        const [serviceAreas] = await Promise.all([
          serviceAreasPromise,
          new Promise(resolve => setTimeout(resolve, 1000))
        ]);

        // A newer search started while we were waiting — discard this result
        if (_gen !== _displayGen) return;

        if (!serviceAreas || !Array.isArray(serviceAreas) || serviceAreas.length === 0) {
          document.querySelector('#no-service-area-container').innerHTML = `
            <div class="fs-7">No service areas found in ${stateCode}.</div>
          `;
          document.querySelector('#no-results-container').innerHTML = `
            <p class="mb-2">No locations found within 50 miles of your search location in ${county || ''}, ${stateCode}.</p>
          `;
          return;
        }

        // Service areas found — show the "no locations" message and set up the service areas container
        document.querySelector('#no-results-container').innerHTML = `
          <p class="mb-2">No locations found within 50 miles of your search location in ${county || ''}, ${stateCode}.</p>
          <div id="service-areas-container" class="mt-4"></div>
        `;

        // Update the UI with basic service area structure
        document.getElementById('service-areas-container').innerHTML = `
          <span class="fs-7 mb-3">Service Areas in ${stateCode}</span>
          <div class="row g-3" id="service-areas-row"></div>
        `;
        
        const serviceAreasRow = document.getElementById('service-areas-row');
        
        // Create all area cards with placeholders for services
        serviceAreas.forEach((area, index) => {
          const areaElement = document.createElement('div');
          areaElement.className = 'col-md-6 mb-4';
          areaElement.innerHTML = `
            <div class="location-finder-results bg-light rounded-5 overflow-hidden p-8">
              <div class="d-flex flex-column gap-4 justify-content-between h-100">
                <div>
                  <h4 class="display-1 fs-md-7">${area.name || 'Service Area'}</h4>
                </div>
                <div class="mb-auto">
                  <div class="border-top border-2 border-dark-50 d-flex align-items-center justify-content-between py-3">
                    <span class="display-4 display-md-1">Description</span>
                    <div class="text-dark-50 ms-auto me-2 display-4 display-md-1">
                      <span>${area.description || 'No description available'}</span>
                    </div>
                  </div>
                  ${area.contact_name ? `
                    <div class="d-flex align-items-center justify-content-between py-3">
                      <span class="display-4 display-md-1">Contact Name</span>
                      <div class="text-dark-50 display-4 display-md-1">
                        <span>${area.contact_name}</span>
                      </div>
                    </div>
                  ` : ''}
                  ${area.contact_number ? `
                    <div class="d-flex align-items-center justify-content-between py-3">
                      <span class="display-4 display-md-1">Contact Number</span>
                      <div class="text-dark-50 display-4 display-md-1">
                        <span>${area.contact_number}</span>
                      </div>
                    </div>
                  ` : ''}
                  ${area.email ? `
                    <div class="d-flex align-items-center justify-content-between py-3">
                      <span class="display-4 display-md-1">Email Address</span>
                      <div class="text-dark-50 display-4 display-md-1">
                        <span>${area.email}</span>
                      </div>
                    </div>
                  ` : ''}
                  <div class="border-top border-2 border-dark-50 py-3">
                    <span class="display-md-1 display-4">Services Offered</span>
                    <div class="pt-3">
                      <div class="row row-cols-2 row-cols-md-3 g-3" id="service-list-${index}">
                        <div class="col">Loading services...</div>
                      </div>
                    </div>
                  </div>
                </div>
                ${area.url ? `
                  <div class="d-flex gap-2">
                    <a href="${area.url}" class="btn btn-info d-flex align-items-center justify-content-center w-100 display-4">
                      <span class="material-symbols-outlined text-light me-2">arrow_outward</span>
                      View Service Area Details
                    </a>
                  </div>
                ` : ''}
              </div>
            </div>
          `;
          
          serviceAreasRow.appendChild(areaElement);
        });
        
        // After all cards are rendered, fetch and attach services in the background
        // This ensures the UI is responsive while services load
        setTimeout(() => {
          serviceAreas.forEach((area, index) => {
            
            getServicesForServiceArea(area).then(areaServices => {
              const serviceListContainer = document.getElementById(`service-list-${index}`);
              if (serviceListContainer) {
                if (areaServices && areaServices.length > 0) {
                  serviceListContainer.innerHTML = areaServices.map(service => `
                    <div class="col">
                      <div class="d-flex align-items-center">
                        <span class="material-symbols-outlined text-primary-200 display-6">${service.content.icon_name}</span>
                        <span class="display-4 display-md-1 ms-2">${service.meta.title}</span>
                      </div>
                    </div>
                  `).join('');
                } else {
                  serviceListContainer.innerHTML = '<div class="col">No services available</div>';
                }
              }
            }).catch(err => {
              console.error('Error loading services for area:', err);
              const serviceListContainer = document.getElementById(`service-list-${index}`);
              if (serviceListContainer) {
                serviceListContainer.innerHTML = '<div class="col">Error loading services</div>';
              }
            });
          });
        }, 100); // Short delay to let the UI render first
        
      } catch (error) {
        console.error('Error getting location details:', error);
        if (_gen !== _displayGen) return;
        document.querySelector('#no-results-container').innerHTML = `
          <div class="col-12">
            <div class="alert alert-info">
              No locations found within 50 miles of your search location in ${county || ''}, ${stateCode}.
            </div>
          </div>
        `;
      }
    })();
    
    return;
  }

  // Show a loading placeholder while we render all the location cards
  if (locations.length > 0) {
    // Only add this if we have locations to display
    resultsContainer.innerHTML = `
      <div class="col-12 text-center py-3 location-loading-indicator">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 display-4">Preparing location data...</p>
      </div>
    `;
  }
  // Use setTimeout to give the browser a chance to render the loading indicator
  setTimeout(() => {
    // Clear the loading indicator
    resultsContainer.innerHTML = '';
    
    const paginatedLocations = getPaginatedData(locations, currentPage, itemsPerPage);
  
    paginatedLocations.forEach((loc, index) => {
      const distance = window.calculateDistance(
        window.currentSearchLocation.lat,
        window.currentSearchLocation.lng,
        loc.latitude,
        loc.longitude
      ).toFixed(1);

      const locationDiv = document.createElement('div');
      locationDiv.className = 'col-md-6 mb-4 location-card position-relative';
      locationDiv.setAttribute('data-location-id', loc.zuid);
      
      // Get the territory, division, and corps from location data
      const orgDetails = loc.organization_details || '';
      const services = loc.services ? loc.services.map(s => s.title).join(',') : '';
      const address = addressBuilder(loc?.address, loc?.city, loc?.state, loc?.zipcode);
      const hasServiceTypes = !!(loc.service_types && loc.service_types.trim().length);
      // console.log(`LatLOng ${loc.name} ${address}`, loc.latitude,
      //   loc.longitude, window.currentSearchLocation.lat,
      //   window.currentSearchLocation.lng)
      let generalHours = '';
      if(stripos('Contact Store for hours', loc.hours_of_operation)) {
        generalHours = 'Contact location for hours';
      } else if (stripos('Contact for hours', loc.hours_of_operation)) {
        generalHours = 'Contact location for hours';
      } else {
        generalHours = loc.hours_of_operation;
      }
      locationDiv.innerHTML = `
        <div class="location-finder-results bg-light rounded-5 overflow-hidden p-8">
          <div class="d-flex flex-column gap-4 justify-content-between h-100">
            <div>
              <h4 class="display-1 fs-md-7 d-flex align-items-center">
                <div class="pin-icon"></div>
                <span>${loc.name || 'Salvation Army Location'}</span>
              </h4>
              <p class="display-4 display-md-2 text-primary-200">${distance} miles away from your location</p>
            </div>
            <div class="mb-auto">
              <div class="border-top border-2 border-dark-50 d-flex align-items-center justify-content-between py-3">
                <span class="display-4 display-md-1">General Hours</span>
                <div class="form-control text-dark-50 ms-auto me-2 display-4 display-md-1 w-75 text-end">
                  <span>${generalHours || 'Hours not available'}</span>
                </div>
                
              </div>
              <div class="d-flex align-items-center justify-content-between py-3">
                <span class="display-4 display-md-1">Phone</span>
                <div class="text-dark-50 display-4 display-md-1">
                  
                  <a 
                    href="tel:${loc.contact_number}"
                    target="_blank"
                    rel="noopener noreferrer"
                    data-link-location-type="body:map"
                    data-link-function-type="other"
                    data-link-format-type="button"
                    data-link-type="internal"
                    data-location-id="${loc.zuid}"
                    data-location-name="${loc.name}"
                    data-location-org-detail="${orgDetails}"
                    data-location-services="${services}"
                    onclick="LocationTrackingSearchEvent(this,'location_search_results_click')"
                >
                    <span>${loc.contact_number || 'Phone not available'}</span>
                </a>
                </div>
              </div>
              <div class="d-flex align-items-center justify-content-between py-3">
                <span class="display-4 display-md-1">Address</span>
                <div class="text-dark-50 display-4 display-md-1">
                  
                  <a 
                      href="https://www.google.com/maps?q=${address}" 
                      target="_blank"
                      rel="noopener noreferrer"
                      data-link-location-type="body:map"
                      data-link-function-type="other"
                      data-link-format-type="button"
                      data-link-type="internal"
                      data-location-id="${loc.zuid}"
                      data-location-name="${loc.name}"
                      data-location-org-detail="${orgDetails}"
                      data-location-services="${services}"
                      onclick="LocationTrackingSearchEvent(this,'location_search_results_click')"
                  >
                      <span>${address || 'Address not available'}</span>
                  </a>
                </div>
              </div>
              <div class="d-flex align-items-center justify-content-between py-3">
                <span class="display-4 display-md-1">Directions</span>
                <div class="text-dark-50 display-4 display-md-1">
                  <a
                          href="https://www.google.com/maps/dir/?api=1&origin=current-location&destination=${address}&travelmode=walking"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-dark-50 me-2"
                          data-link-location-type="body:map"
                          data-link-function-type="other"
                          data-link-format-type="button"
                          data-link-type="external"
                          data-location-id="${loc.zuid}"
                          data-location-name="${loc.name}"
                          data-location-org-detail="${orgDetails}"
                          data-location-services="${services}"
                          onclick="LocationTrackingSearchEvent(this,'location_search_results_click')"
                      >Walking</a>
                      <a
                          href="https://www.google.com/maps/dir/?api=1&origin=current-location&destination=${address}&travelmode=driving"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-dark-50 me-2"
                          data-link-location-type="body:map"
                          data-link-function-type="other"
                          data-link-format-type="button"
                          data-link-type="external"
                          data-location-id="${loc.zuid}"
                          data-location-name="${loc.name}"
                          data-location-org-detail="${orgDetails}"
                          data-location-services="${services}"
                          onclick="LocationTrackingSearchEvent(this,'location_search_results_click')"
                      >Driving</a>
                      <a
