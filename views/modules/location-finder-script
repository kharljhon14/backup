// Replace or modify the existing getServiceTypes function
async function getServiceTypes() {
  // If we already have the data cached, return it immediately
  if (window.serviceTypesCache) {
    return window.serviceTypesCache;
  }
  
  // If we're already in the process of fetching, don't start another request
  if (window.serviceTypesPromise) {
    return window.serviceTypesPromise;
  }
  
  // Start a new fetch and save the promise
  window.serviceTypesPromise = new Promise(async (resolve, reject) => {
    try {
      const response = await fetch('https://{{instance.domain}}/-/instant/6-f0f2e8c49b-sdbvrb.json');
      const { data } = await response.json();
      
      // Save the result in the cache
      window.serviceTypesCache = data;
      resolve(data);
    } catch (error) {
      console.error('Error fetching service types:', error);
      // Clear the promise so we can try again next time
      window.serviceTypesPromise = null;
      reject(error);
    }
  });
  
  return window.serviceTypesPromise;
}

