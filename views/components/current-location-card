
<div class="container mt-4 bg-light rounded-5 px-8 py-8">
    <div class="row">
        <div class="col-md-6 d-md-flex justify-content-between align-items-center mb-4 mb-md-0">
            <h2 class="current-card__title fs-5 fs-md-4 mb-0"></h2>
            <p class="current-card__distance text-primary-200 display-1 mb-0"></p>
        </div>
        <div class="col-md-6">
            <h2 class="fs-4 d-none d-md-block mb-0">Services Available</h2>
        </div>
    </div>

    <div class="row mt-4 gx-14">
        <div class="col-md-6 py-5">
            <!-- Desktop version (visible on md screens and up) -->
            <div class="d-none d-md-flex justify-content-between align-items-start border-2 border-top py-5">
                <div class="col-md-3">
                    <h3 class="text-dark-100 fs-7 mb-0">General Hours</h3>
                </div>
                <div class="col-md-7">
                    <div class="row">
                        <div class="col-12 d-flex justify-content-between text-start">
                            <span></span>
                            <div class="current-card__hours text-dark-50 fs-7 fw-normal"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile version (visible on screens smaller than md) -->
            <div class="d-md-none">
                <div class="accordion" id="generalHoursAccordion">
                    <div class="accordion-item border-0">
                        <h2 class="accordion-header border-0" id="generalHoursHeading">
                            <button class="accordion-button bg-transparent border-0 px-0" type="button" data-bs-toggle="collapse" data-bs-target="#generalHoursCollapse" aria-expanded="true" aria-controls="generalHoursCollapse">
                                <h3 class="text-dark-100 display-3 mb-0">General Hours</h3>
                            </button>
                        </h2>
                        <div id="generalHoursCollapse" class="accordion-collapse collapse show" aria-labelledby="generalHoursHeading" data-bs-parent="#generalHoursAccordion">
                            <div class="accordion-body p-0">
                                <div class="row">
                                    <div class="col-12">
                                        <div class="d-flex justify-content-between align-items-center py-5">
                                            <span class="current-card__title text-dark-50 display-3 fw-normal">Monday</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center py-5 border-top border-2">
                <h3 class="text-dark-100 display-3 fs-md-7 mb-0">Phone</h3>
                <p class="current-card__phone text-dark-50 me-2 display-4 fs-md-7"></p>
            </div>

            <div class="d-flex justify-content-between align-items-center py-5 border-top border-2">
                <h3 class="text-dark-100 display-3 fs-md-7 mb-0">Address</h3>
                <p class="current-card__address text-dark-50 me-2 display-4 fs-md-7"></p>
            </div>

            <div class="d-flex justify-content-between align-items-center py-5 border-top border-2">
                <h3 class="text-dark-100 display-3 fs-md-7 mb-0">Directions</h3>
                <p class="text-dark-50 me-2 display-4 fs-md-7">
                    <a href="#" class="text-dark-50 display-3 fs-md-7 text-underline">Walking</a>
                    <a href="#" class="text-dark-50 display-3 fs-md-7 text-underline">Driving</a>
                    <a href="#" class="text-dark-50 display-3 fs-md-7 text-underline">Public Transport</a>
                </p>
            </div>
        </div>

        <div class="col-md-6 py-5">
            <h3 class="fs-6 fs-md-4 d-md-none mb-4">Services Available</h3>
            <div class="current-location__services"></div>
        </div>
    </div>
</div>


<script>
  const buildServices = async () => {
    const services = await window.fetchServicesForLocation('{{request.queryParam(zuid)}}');
    const serviceContainer = document.querySelector('.current-location__services'); // Remember to add your selector here
    let servicesHTML = '';
    if(services.length > 0) {
        servicesHTML = services
        .map((service, index) => {
            // Create a new row for every even index (0, 2, 4, etc)
            if (index % 2 === 0) {
                return `
                    <div class="row border-2 border-top py-5">
                        <div class="col-6 col-md-6">
                            <p class="d-inline-flex align-items-center justify-content-start">
                                <span class="material-symbols-outlined me-4 text-primary-200">
                                    ${service.service_type.data[0].icon_name}
                                </span>
                                <a href="${service.meta.web.url}" class="text-dark-50 display-4 display-md-1 text-underline">
                                    ${service.title}
                                </a>
                            </p>
                        </div>
                        ${services[index + 1] ? `
                            <div class="col-6 col-md-6">
                                <p class="d-inline-flex align-items-center justify-content-start">
                                    <span class="material-symbols-outlined me-4 text-primary-200">
                                        ${services[index + 1].service_type.data[0].icon_name}
                                    </span>
                                    <a href="${services[index + 1].meta.web.uri}" class="text-dark-50 display-4 display-md-1 text-underline">
                                        ${services[index + 1].title}
                                    </a>
                                </p>
                            </div>
                        ` : ''}
                    </div>
                `;
            }
            return null;
        })
        .filter(row => row !== null)
        .join('');
    }

    if (serviceContainer) {
        serviceContainer.innerHTML = servicesHTML;
    }
}

document.addEventListener('DOMContentLoaded', function() {
    buildServices();
});
</script>

