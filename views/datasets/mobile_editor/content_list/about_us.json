{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "%%" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}
{{$queryFilter = about.title LIKE {$search} AND about.location IS NULL AND about.division IS NULL AND about.territory IS NULL AND national = 1 }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}

{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{$queryFilter = about.title LIKE {$search} AND about.location = {$property} }}
{{else}}
{{$property = "" }}
{{end-if}}

{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{$queryFilter = about.title LIKE {$search} AND about.division = {$division} AND about.location IS NULL}}
{{else}}
{{$division = "" }}
{{end-if}}


{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{$queryFilter = about.title LIKE {$search} AND about.territory = {$territory} AND about.location IS NULL AND about.division IS NULL}}
{{else}}
{{$territory = "" }}
{{end-if}}



{
    "data": [
      
            {{each about_us as about WHERE {$queryFilter} LIMIT {$skip}, {$limit} SORT BY about.{$sort_by} {$sort_order} }}
            {{$totalItems = {about._num} }}         
                {
                "data": {
                    "title": "{{about.title.escapeForJs()}}",
                    "description": "Last modified {{event.updated_at.date(m/d/Y)}}",
                    "image": "{{about.hero_image}}",
                    "property":  "{{about.location)}}",
                    "division": "{{about.division}}",
                    "url_path": "{{about.getUrl()}}"
                    },
                "meta": {
                    "ZUID": "{{about.zuid}}",
                    "masterZuid": "{{about.zuid}}",
                    "contentModelZuid": "{{about.set_zuid}}",
                    "meta_title": "{{cu.seo_meta_title.escapeForJs()}}"
                    }
                 } {{event._arraycomma}}
            
            {{/each}}

      
         
           
     
    ],
  
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}