{{$skip = 0 }}
{{$limit = 20 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "" }}
{{$property = "" }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}


{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = name }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{else}}
{{$property = "" }}
{{end-if}}


{{each locations as location WHERE location.zuid = {$property} }}
{{$totalItems = {location._num} }}
{{/each}}

{
    "data": [
        {{each locations as location WHERE location.zuid = {$property} AND location.name LIKE {$search} LIMIT {$skip}, {$limit} SORT BY location.{$sort_by} {$sort_order} }}
        {
            "data": {
                "title": "{{location.name.escapeForJs()}}",
                "description": "Last modified {{location.updated_at.date(m/d/Y)}}",
                "image": "{{location.og_image}}",
                "property":  "{{location.zuid}}"
            },
            "meta": {
                "ZUID": "{{location.zuid}}",
                "masterZuid": "{{location.zuid}}",
                "contentModelZuid": "{{location.set_zuid}}"
            }
        } {{location._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}}
    }
}