      <div class="col-md-4 mt-4">
        <h4 class="display-2 text-dark-50 mb-2">Find local help</h4>
        <div class="input-group mb-3">
          <input type="text" class="form-control" placeholder="Enter your city, address, or zip code" aria-label="Enter your city, address, or zip code" id="pac-input">
        </div>
        <button class="btn btn-outline-danger w-100 mb-3 d-flex align-items-center justify-content-end text-primary-200 display-1 use-my-location">
          <span class="material-symbols-outlined me-2">
            my_location
          </span> Use My Location
        </button>
        <button class="btn btn-primary w-100" onclick="searchServices()">
          Search Services
        </button>
