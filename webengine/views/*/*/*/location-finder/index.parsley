{{$state = {request.pathpart(1)} }}
{{$city = {request.pathpart(2)} }}
{{$location = {request.pathpart(3)} }}
{{$url = /{$state}/{$city}/{$location}/ }}


{{each locations as location}}
  {{if {$url} == {location.path_full} }}
    {{$location_zuid = {location.zuid} }}
  {{/if}}
{{/each}}

{{if {$location_zuid} }}
<div id="location-finder" class="location-finder container" data-component-type="location-finder">
  <div class="mb-15 nico">
    <h1 class="fs-4 mb-8">{{locations.filter(path_full like '%{$url}%').name}} Information</h1>
    
<div class="container mt-4 bg-light rounded-5 px-8 py-8">
    <div class="row">
        <div class="col-md-6 d-md-flex justify-content-between align-items-center mb-4 mb-md-0">
            <h1 class="fs-5 fs-md-4">{{locations.filter(path_full like '%{$url}%' ).name}}</h1>
            <p class="text-primary-200 display-1">3.5 miles away from your general location</p>
        </div>
        <div class="col-md-6">
            <h2 class="fs-4 d-none d-md-block">Services Available</h2>
        </div>
    </div>

    <div class="row mt-4 gx-14">
        <div class="col-md-6 py-5">
            <!-- Desktop version (visible on md screens and up) -->
            <div class="d-none d-md-flex justify-content-between align-items-start border-2 border-top py-3">
                <div class="col-md-3">
                    <h3 class="text-dark-100 fs-7">General Hours</h3>
                </div>
                <div class="col-md-9">
                    <div class="row">
                        <div class="col-12 d-flex justify-content-between mb-5 text-end">
                            <span class="text-dark-50 fs-7 fw-normal">Monday</span>
                            <span class="text-dark-50 fs-7 fw-normal">Open 9:00 AM</span>
                            <span class="text-dark-50 fs-7 fw-normal">|</span>
                            <span class="text-dark-50 fs-7 fw-normal">Closes 12:00 PM</span>
                        </div>
                        <div class="col-12 d-flex justify-content-between mb-5">
                            <span class="text-dark-50 fs-7 fw-normal">Tuesday</span>
                            <span class="text-dark-50 fs-7 fw-normal">Open 9:00 AM</span>
                            <span class="text-dark-50 fs-7 fw-normal">|</span>
                            <span class="text-dark-50 fs-7 fw-normal">Closes 12:00 PM</span>
                        </div>
                        <div class="col-12 d-flex justify-content-between mb-5">
                            <span class="text-dark-50 fs-7 fw-normal">Wednesday</span>
                            <span class="text-dark-50 fs-7 fw-normal">Open 9:00 AM</span>
                            <span class="text-dark-50 fs-7 fw-normal">|</span>
                            <span class="text-dark-50 fs-7 fw-normal">Closes 12:00 PM</span>
                        </div>
                        <div class="col-12 d-flex justify-content-between mb-5">
                            <span class="text-dark-50 fs-7 fw-normal">Thursday</span>
                            <span class="text-dark-50 fs-7 fw-normal">Open 9:00 AM</span>
                            <span class="text-dark-50 fs-7 fw-normal">|</span>
                            <span class="text-dark-50 fs-7 fw-normal">Closes 12:00 PM</span>
                        </div>
                        <div class="col-12 d-flex justify-content-between mb-5">
                            <span class="text-dark-50 fs-7 fw-normal">Friday</span>
                            <span class="text-dark-50 fs-7 fw-normal">Open 9:00 AM</span>
