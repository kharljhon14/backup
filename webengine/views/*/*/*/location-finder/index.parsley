  <div id="location-results" class="location-results mt-15" style="display: none;">
    <div class="fs-4 result-text mb-8"></div>
    <div class="location-results__list row gx-4">
      <!-- Location results will be dynamically inserted here -->
    </div>
  </div>
</div>

<script>
async function getProperty() {
  try {
    const response = await fetch(`https://{{instance.domain}}/location-finder.json?query={{$location_zuid}}`);
    const rawData = await response.text(); 
    const data = JSON.parse(rawData);
    return data.address || null;
  } catch (error) {
    console.error('Error fetching property:', error);
    return null;
  }
}

async function searchServices() {
  const location = document.getElementById('pac-input').value;
  window.searchLocation(location);
  
  // Add the search term to the .result-text div
  const resultTextDiv = document.querySelector('.result-text');
  resultTextDiv.textContent = `Search results for: ${location}`;

  // Show the location-results section
  const locationResults = document.getElementById('location-results');
  locationResults.style.display = 'block';

  try {
    // Get the locations data
    const locations = await window.fetchLocationData();
    
    // Get the geocoded location
    const geocoder = new google.maps.Geocoder();
    const geocodeResult = await new Promise((resolve, reject) => {
      geocoder.geocode({ address: location, componentRestrictions: { country: 'US' } }, (results, status) => {
        if (status === "OK" && results.length > 0) {
          resolve(results[0].geometry.location);
        } else {
          reject(new Error("Geocoding failed"));
        }
      });
    });

    // Filter locations within 50 miles
    const filteredLocations = locations.filter(loc => {
      if (!loc || !loc.latitude || !loc.longitude) return false;
      
      const distance = window.calculateDistance(
        geocodeResult.lat(),
        geocodeResult.lng(),
        loc.latitude,
        loc.longitude
      );
      return distance <= 50;
    });

    // Sort locations by distance
    filteredLocations.sort((a, b) => {
      const distanceA = window.calculateDistance(
        geocodeResult.lat(),
        geocodeResult.lng(),
        a.latitude,
        a.longitude
      );
      const distanceB = window.calculateDistance(
        geocodeResult.lat(),
        geocodeResult.lng(),
        b.latitude,
        b.longitude
      );
      return distanceA - distanceB;
    });

    // Clear existing results
    const resultsContainer = document.querySelector('.location-results__list');
    resultsContainer.innerHTML = '';

    // Build and append HTML for each location
    filteredLocations.forEach((loc, index) => {
      const distance = window.calculateDistance(
        geocodeResult.lat(),
        geocodeResult.lng(),
        loc.latitude,
        loc.longitude
      ).toFixed(1);

      const locationHtml = `
        <div class="col-md-6 mb-4">
          <div class="location-finder-results bg-light rounded-5 overflow-hidden p-8">
            <div class="d-flex flex-column gap-4 justify-content-between h-100">
              <div>
                <h4 class="display-1 fs-md-7">${loc.name || 'Salvation Army Location'}</h4>
                <p class="display-4 display-md-2 text-primary-200">${distance} miles away from your location</p>
              </div>
              <div class="mb-auto">
                <div class="border-top border-2 border-dark-50 d-flex align-items-center justify-content-between py-3">
                  <span class="display-4 display-md-1">General Hours</span>
                  <div class="text-dark-50 ms-auto me-2 display-4 display-md-1">
                    <span>${loc.hours_of_operation || 'Hours not available'}</span>
                  </div>
                  <button class="btn p-0 d-flex align-items-center justify-content-center">
                    <span class="material-symbols-outlined text-dark-50">add</span>
                  </button>
                </div>
                <div class="d-flex align-items-center justify-content-between py-3">
                  <span class="display-4 display-md-1">Phone</span>
                  <div class="text-dark-50 display-4 display-md-1">
                    <span>${loc.contact_number || 'Phone not available'}</span>
                  </div>
                </div>
                <div class="d-flex align-items-center justify-content-between py-3">
                  <span class="display-4 display-md-1">Address</span>
                  <div class="text-dark-50 display-4 display-md-1">
                    <span>${loc.address || 'Address not available'}</span>
                  </div>
                </div>
                <div class="d-flex align-items-center justify-content-between py-3">
                  <span class="display-4 display-md-1">Directions</span>
                  <div class="text-dark-50 display-4 display-md-1">
                    <span>Walking</span>
                    <span>Driving</span>
                    <span>Public Transport</span>
                  </div>
                </div>
                <div class="border-top border-2 border-dark-50 py-3">
                  <div class="accordion" id="servicesAccordion${index}">
                    <div class="accordion-item border-0">
                      <h2 class="accordion-header" id="servicesHeading${index}">
                        <button class="accordion-button collapsed p-0 bg-transparent shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#servicesCollapse${index}" aria-expanded="false" aria-controls="servicesCollapse${index}">
                          <div class="d-flex align-items-center justify-content-between w-100">
                            <span class="display-2 fs-md-7">Services Offered</span>
                            <span class="text-dark-50 text-decoration-none display-2 fs-md-7 me-1">View More</span>
                          </div>
                        </button>
                      </h2>
                      <div id="servicesCollapse${index}" class="accordion-collapse collapse" aria-labelledby="servicesHeading${index}" data-bs-parent="#servicesAccordion${index}">
                        <div class="accordion-body p-0 pt-3">
                          <div class="row row-cols-2 row-cols-md-3 g-3">
                            ${(loc.services || []).map(service => `
                              <div class="col">
                                <div class="d-flex align-items-center">
                                  <span class="material-symbols-outlined text-danger me-2">home</span>
                                  <span class="display-4 fs-md-7">${service}</span>
                                </div>
                              </div>
                            `).join('')}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="d-flex gap-2">
                <a href="${loc.url || '#'}" class="btn btn-info d-flex align-items-center justify-content-center w-100 display-4">
                  <span class="material-symbols-outlined text-light me-2">arrow_outward</span>
                  View Location Website
                </a>
                <button class="btn btn-secondary d-flex align-items-center justify-content-center w-100 display-4">
                  <span class="material-symbols-outlined text-light me-2">arrow_outward</span>
                  View Service Hours & Info
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
      resultsContainer.insertAdjacentHTML('beforeend', locationHtml);
    });

    if (filteredLocations.length === 0) {
      resultsContainer.innerHTML = `
        <div class="col-12">
          <div class="alert alert-info">
            No locations found within 50 miles of your search location.
          </div>
        </div>
      `;
    }

  } catch (error) {
    console.error('Error in searchServices:', error);
    const resultsContainer = document.querySelector('.location-results__list');
    resultsContainer.innerHTML = `
      <div class="col-12">
        <div class="alert alert-danger">
          Error searching for locations. Please try again.
        </div>
      </div>
    `;
  }
}

// Add event listener for the "Use My Location" button
document.addEventListener('DOMContentLoaded', function() {
  const useMyLocationButton = document.querySelector(".use-my-location");
  if (useMyLocationButton) {
    useMyLocationButton.addEventListener("click", window.getCurrentLocation);
  }
});
</script>


<style>
  @media (max-width: 767px) {
    .dropdown-toggle {
      background-color: #f8f9fa;
      border-color: #ced4da;
    }
    .services-filter .dropdown-menu {
      position: static !important;
      width: 100%;
      margin-top: 0.5rem;
      box-shadow: none;
      border: 1px solid #ced4da;
      min-width: unset !important;
      transform: translate3d(0, 1rem, 0) !important;
    }
    .dropdown-item {
      padding: 10px 15px;
    }
    .dropdown-item label {
      margin-bottom: 0;
    }
    .dropdown-item .icon {
      font-size: 20px;
      width: 30px;
      text-align: center;
    }
    .form-check-input {
      width: 20px;
      height: 20px;
      margin-left: auto;
    }
    .btn-secondary {
      background-color: #6c757d;
      border-color: #6c757d;
    }
    .btn-primary {
      background-color: #0056b3;
      border-color: #0056b3;
    }
  }
</style>
{{else}}
  {{response.return404(Location Not Found)}}
{{/if}}
