      if (data) {
        return data;
      } else {
        return false;
      }
    } catch (error) {
      console.error('Error in fetchPageData:', error);
      return false;
    }
  }
  // Initialize when the page loads
  document.addEventListener('DOMContentLoaded', async function () {
    setTimeout(async () => {
      await buildServiceCheckboxes();
    }, 1000);
  });
