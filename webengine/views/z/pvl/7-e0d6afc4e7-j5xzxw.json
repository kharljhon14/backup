{"layout:root:column:0":{"name":"layout:root:column:0","html":"<div className={styles.pvlRoot}>*</div>","children":{"content:text:0:91":{"icon":"text-height","name":"Heading","type":"text","html":"<h1 class=\"mb-8 fs-4 px-2\">Faith and Fellowship</h1>","description":"Plain Text","draggable":true,"content":"Faith and Fellowship","position":0,"fullName":"content:text:0:91","htmlElement":"h1","primarytype":"content","newLoc":"layout:root:column:0","oldLoc":"bank","id":"content:text:0:91","styles":{},"classes":"mb-8 fs-4 px-2","contentOverride":false},"design:columns:1 column - 1 row:0:86":{"uid":"301","name":"1 column - 1 row","type":"columns","html":"<div style=\"display:flex\" classname=\"{styles.pvlRow}\" class=\"bg-white p-5 rounded-5 mb-18\">*</div>","preview":"<div style=\"display:flex;flex-direction:row;min-height:20px;\"><div style=\"flex:1\" className={styles.pvlColumn}></div></div>","classes":"bg-white p-5 rounded-5 mb-18","droppable":false,"numberOfColumns":1,"widthPerColumns":"1","columns":[{"width":1,"html":"<div style=\"flex:1\" className={styles.pvlColumn}>*</div>","classes":"column","droppable":true}],"groupCategory":"isNew","group":"","position":1,"fullName":"design:columns:1 column - 1 row:0:86","children":{"design:columns:1 column - 1 row:0:86-1:1 column - 1 row:0":{"width":1,"html":"<div style=\"flex:1\" className={styles.pvlColumn}>*</div>","classes":"column","droppable":true,"children":{"content:video:0:0":{"html":"<video width=\"100%\" src=\"https://8hxvw8tw.media.zestyio.com/the-salvation-army-new-york-promo-video-home-2025.mp4\" alt=\"placeholder\" controls=\"\" class=\"rounded-4 mb-8\"></video>","content":"<video width=\"100%\" src=\"https://8hxvw8tw.media.zestyio.com/the-salvation-army-new-york-promo-video-home-2025.mp4\" alt=\"placeholder\" controls=\"\" class=\"rounded-4 mb-8\"></video>","name":"Video","position":0,"fullName":"content:video:0:0","htmlElement":"video","type":"video","primarytype":"content","newLoc":"design:columns:1 column - 1 row:0:86-1:1 column - 1 row:0","oldLoc":"bank","id":"content:video:0:0","styles":{},"classes":"rounded-4 mb-8","contentOverride":false},"content:wysiwyg_basic:0:60":{"icon":"outdent","name":"WYSIWYG","type":"wysiwyg_basic","html":"<p data-start=\"296\" data-end=\"331\"><strong data-start=\"296\" data-end=\"329\">Making a Difference Every Day</strong></p>\n<p data-start=\"333\" data-end=\"448\">Here at The Salvation Army, we do good things — real, meaningful things that make a difference in people’s lives.</p>\n<p data-start=\"450\" data-end=\"620\">We help families find <em data-start=\"472\" data-end=\"497\">food, shelter, and hope</em>; support children with <strong data-start=\"521\" data-end=\"550\">education and life skills</strong>; and stand alongside communities during times of need and disaster.<br><br></p>\n<p data-start=\"627\" data-end=\"659\"><strong data-start=\"627\" data-end=\"657\">How We Serve the Community</strong></p>\n<ul data-start=\"661\" data-end=\"1424\">\n<li data-start=\"661\" data-end=\"817\">\n<p data-start=\"663\" data-end=\"817\"><strong data-start=\"663\" data-end=\"694\">Community Support &amp; Relief:</strong> Providing essential aid during crises and natural disasters.</p>\n</li>\n<li data-start=\"818\" data-end=\"982\">\n<p data-start=\"820\" data-end=\"982\"><strong data-start=\"820\" data-end=\"851\">Education &amp; Youth Programs:</strong> Offering learning opportunities, skills training, and scholarships.</p>\n</li>\n<li data-start=\"983\" data-end=\"1130\">\n<p data-start=\"985\" data-end=\"1130\"><strong data-start=\"985\" data-end=\"1007\">Shelter &amp; Housing:</strong> Safe and comfortable housing for families and individuals in need.</p>\n</li>\n<li data-start=\"1131\" data-end=\"1280\">\n<p data-start=\"1133\" data-end=\"1280\"><strong data-start=\"1133\" data-end=\"1164\">Health &amp; Wellness Services:</strong> Access to medical care, wellness activities, and health education.</p>\n</li>\n<li data-start=\"1281\" data-end=\"1424\">\n<p data-start=\"1283\" data-end=\"1424\"><strong data-start=\"1283\" data-end=\"1317\">Volunteer &amp; Outreach Programs:</strong> Opportunities for individuals and groups to serve their communities.<em data-start=\"1387\" data-end=\"1422\"><br></em></p>\n</li>\n</ul>\n<p><em data-start=\"1387\" data-end=\"1422\"></em></p>\n<p data-start=\"1431\" data-end=\"1461\"><strong data-start=\"1431\" data-end=\"1459\">Why Your Support Matters</strong></p>\n<p data-start=\"1463\" data-end=\"1690\">Every act of service, donation, and volunteer effort contributes to building <strong data-start=\"1540\" data-end=\"1584\">stronger, more compassionate communities</strong>.<br data-start=\"1585\" data-end=\"1588\">We believe in meeting people where they are, offering practical help, and empowering them to thrive.</p>\n<ul data-start=\"1692\" data-end=\"1993\">\n<li data-start=\"1692\" data-end=\"1785\">\n<p data-start=\"1694\" data-end=\"1785\">Your donations help provide <strong data-start=\"1722\" data-end=\"1755\">meals, shelter, and education</strong> for those who need it most.</p>\n</li>\n<li data-start=\"1786\" data-end=\"1890\">\n<p data-start=\"1788\" data-end=\"1890\">Volunteering with us gives you a chance to <strong data-start=\"1831\" data-end=\"1856\">directly impact lives</strong> and gain rewarding experiences.</p>\n</li>\n<li data-start=\"1891\" data-end=\"1993\">\n<p data-start=\"1893\" data-end=\"1993\">Partnering with The Salvation Army helps <strong data-start=\"1934\" data-end=\"1966\">strengthen local communities</strong> and expand our outreach.</p>\n</li>\n</ul>","description":"Text with HTML references.","draggable":true,"content":"<p data-start=\"296\" data-end=\"331\"><strong data-start=\"296\" data-end=\"329\">Making a Difference Every Day</strong></p>\n<p data-start=\"333\" data-end=\"448\">Here at The Salvation Army, we do good things — real, meaningful things that make a difference in people’s lives.</p>\n<p data-start=\"450\" data-end=\"620\">We help families find <em data-start=\"472\" data-end=\"497\">food, shelter, and hope</em>; support children with <strong data-start=\"521\" data-end=\"550\">education and life skills</strong>; and stand alongside communities during times of need and disaster.<br><br></p>\n<p data-start=\"627\" data-end=\"659\"><strong data-start=\"627\" data-end=\"657\">How We Serve the Community</strong></p>\n<ul data-start=\"661\" data-end=\"1424\">\n<li data-start=\"661\" data-end=\"817\">\n<p data-start=\"663\" data-end=\"817\"><strong data-start=\"663\" data-end=\"694\">Community Support &amp; Relief:</strong> Providing essential aid during crises and natural disasters.</p>\n</li>\n<li data-start=\"818\" data-end=\"982\">\n<p data-start=\"820\" data-end=\"982\"><strong data-start=\"820\" data-end=\"851\">Education &amp; Youth Programs:</strong> Offering learning opportunities, skills training, and scholarships.</p>\n</li>\n<li data-start=\"983\" data-end=\"1130\">\n<p data-start=\"985\" data-end=\"1130\"><strong data-start=\"985\" data-end=\"1007\">Shelter &amp; Housing:</strong> Safe and comfortable housing for families and individuals in need.</p>\n</li>\n<li data-start=\"1131\" data-end=\"1280\">\n<p data-start=\"1133\" data-end=\"1280\"><strong data-start=\"1133\" data-end=\"1164\">Health &amp; Wellness Services:</strong> Access to medical care, wellness activities, and health education.</p>\n</li>\n<li data-start=\"1281\" data-end=\"1424\">\n<p data-start=\"1283\" data-end=\"1424\"><strong data-start=\"1283\" data-end=\"1317\">Volunteer &amp; Outreach Programs:</strong> Opportunities for individuals and groups to serve their communities.<em data-start=\"1387\" data-end=\"1422\"><br></em></p>\n</li>\n</ul>\n<p><em data-start=\"1387\" data-end=\"1422\"></em></p>\n<p data-start=\"1431\" data-end=\"1461\"><strong data-start=\"1431\" data-end=\"1459\">Why Your Support Matters</strong></p>\n<p data-start=\"1463\" data-end=\"1690\">Every act of service, donation, and volunteer effort contributes to building <strong data-start=\"1540\" data-end=\"1584\">stronger, more compassionate communities</strong>.<br data-start=\"1585\" data-end=\"1588\">We believe in meeting people where they are, offering practical help, and empowering them to thrive.</p>\n<ul data-start=\"1692\" data-end=\"1993\">\n<li data-start=\"1692\" data-end=\"1785\">\n<p data-start=\"1694\" data-end=\"1785\">Your donations help provide <strong data-start=\"1722\" data-end=\"1755\">meals, shelter, and education</strong> for those who need it most.</p>\n</li>\n<li data-start=\"1786\" data-end=\"1890\">\n<p data-start=\"1788\" data-end=\"1890\">Volunteering with us gives you a chance to <strong data-start=\"1831\" data-end=\"1856\">directly impact lives</strong> and gain rewarding experiences.</p>\n</li>\n<li data-start=\"1891\" data-end=\"1993\">\n<p data-start=\"1893\" data-end=\"1993\">Partnering with The Salvation Army helps <strong data-start=\"1934\" data-end=\"1966\">strengthen local communities</strong> and expand our outreach.</p>\n</li>\n</ul>","position":1,"fullName":"content:wysiwyg_basic:0:60","htmlElement":"html","primarytype":"content","newLoc":"design:columns:1 column - 1 row:0:86-1:1 column - 1 row:0","oldLoc":"bank","id":"content:wysiwyg_basic:0:60","styles":{},"contentOverride":false,"classes":""}}}},"primarytype":"design","newLoc":"layout:root:column:0","oldLoc":"bank","id":"design:columns:1 column - 1 row:0:86","styles":{},"htmlElement":"div","content":"<div style=\"display:flex\" classname=\"{styles.pvlRow}\" class=\"bg-white p-5 rounded-5 mb-18\">*</div>","contentOverride":false},"content:block:6-c0e0848e86-z2w5q0:2:79:1:81:0:33:1:6:2:23":{"html":"<div>{{block('/-/block/greatest_need.html?variant=7-f0e8f690c9-m3c8jg')}}</div>","content":"{{block('/-/block/greatest_need.html?variant=7-f0e8f690c9-m3c8jg')}}","model":"6-c0e0848e86-z2w5q0","name":"2","position":2,"fullName":"content:block:6-c0e0848e86-z2w5q0:2:79:1:81:0:33:1:6:2:23","type":"block"