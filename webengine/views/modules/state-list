<!-- HTML -->
<div class="mb-8 bg-light rounded-5 p-8">
  <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap cities-section" id="citiesContainer">
    {{each {cities} as city sort by title ASC where find_in_set('{page.zuid}', state )}}
      <div class="h-100 rounded-5 p-0 bg-area city-card" data-city-name="{{ city.title }}">
        <div class="card-body px-6 py-6">
          <a href="{{truepath({city.zuid})}}" class="state-card-name card-title display-2 text-start text-dark-100 fw-normal">{{ city.title }}</a>
        </div>
      </div>
    {{/each}}
  </div>
</div>

<!-- JavaScript -->
<script>
  const cityCardNames = document.querySelectorAll('.state-card-name');
const regex = /\b(?!\b(?:a|an|the|and|but|or|nor|for|so|yet|as|at|by|in|of|off|on|per|to|up|from|into|onto|over|with)\b)([A-Za-z0-9\u00C0-\u017F]+(?:['-][A-Za-z0-9\u00C0-\u017F]+)*)\b/gi;

  cityCardNames.forEach((cityCardName) => {
    const result = cityCardName.textContent.replace(regex, (word) => {
      return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
    });

    cityCardName.textContent = result;
  });
</script>
