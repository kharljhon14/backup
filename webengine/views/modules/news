<script type="text/javascript">
  let swiper = null;
// News data fetching
const fetchNewsData = async (params = {}) => {
  try {
    const url = new URL(`https://{{instance.domain}}/stories.json`);
    url.searchParams.append('show', params.show || '15');
    url.searchParams.append('limit', params.limit || '0');

    if (params.searchTerm) url.searchParams.append('name', params.searchTerm);
    if (params.filterType === 'most-recent') url.searchParams.append('most-recent', '1');
    if (params.filterType === 'oldest') url.searchParams.append('most-recent', '0');
    if (params.filterType === 'category' && params.filterValue) url.searchParams.append('related-service', params.filterValue);
    if (params.filterType === 'date' && params.selectedDate) {
      const date = new Date(params.selectedDate);
      url.searchParams.append('date', `${date.getMonth() + 1}/${date.getDate()}/${date.getFullYear()}`);
    }

    const response = await fetch(url);
    if (!response.ok) throw new Error('Network response was not ok');
    
    const { data, modelJumpedName } = await response.json();
    return {data: Array.isArray(data) ? data : [], modelJumpedName};
  } catch (error) {
    console.error('Error fetching news:', error);
    return [];
  }
};

// Service type handling
const getServiceType = async (zuid) => {
  try {
    const response = await fetch(`https://{{instance.domain}}/service-types.json?zuid=${zuid}`);
    const serviceType = await response.json();
    
    return serviceType.length > 0 ? `
      <div class="d-flex align-items-center badge bg-white text-danger rounded-5 position-absolute top-3 start-3 px-4 py-2 z-3">
        <i class="material-symbols-outlined me-2 text-primary-200 display-4">${serviceType[0].icon_name}</i>
        <span class="text-dark-100 display-4 fw-normal">${serviceType[0].title}</span>
      </div>
    ` : '';
  } catch (error) {
    console.error('Error fetching service type:', error);
    return '';
  }
};

// News display functions
const createNewsDisplay = () => {
  const container = document.querySelector('.news-swiper .swiper-wrapper');

  const getDefaultServiceType = () => `
    <div class="d-flex align-items-center badge bg-white text-danger rounded-5 position-absolute top-3 start-3 px-4 py-2 z-3">
      <i class="material-symbols-outlined me-2 text-primary-200 display-4">article</i>
      <span class="text-dark-100 display-4 fw-normal">News</span>
    </div>
  `;

  const createNewsSlide = async (story) => {
    const serviceTypeHTML = story.related_service ? 
      await getServiceType(story.related_service.meta.zuid) : 
      getDefaultServiceType();
    const storyImageBase = story.image ? story.image : 'https://8hxvw8tw.media.zestyio.com/SAL_EmptyStates_SAL_IndivCards_Newsroom-6.HkGLWVDrfbx.jpg';
    const storyImageMobile = `${storyImageBase}?width=396&height=222&crop=16:9,smart&quality=100`;
    const storyImageDesktop = `${storyImageBase}?width=338&height=190&crop=16:9,smart&quality=100`;
    const formattedDate = dateFormatter(story.date);
    
    return `
      <div class="swiper-slide rounded-5">
        <div class="card rounded-5 overflow-hidden w-100" style="height:400px">
          <div class="card-img-top bg-secondary bg-opacity-25 position-relative overflow-hidden">
            ${serviceTypeHTML}
            
            <div class="position-absolute bottom-4 start-0 d-flex align-items-center justify-content-between w-100 px-6 text-light display-4 z-3">
              <span class="d-block author">${formattedDate}</span>
              ${story.author ? `<span>By ${story.author}</span>` : ''}
            </div>
            
            <div class="ratio ratio-4x3 bg-secondary bg-opacity-25 position-relative overflow-hidden">
              <img
                class="w-100 h-100 object-fit-cover"
                src="${storyImageDesktop}"
                srcset="${storyImageMobile} 396w, ${storyImageDesktop} 338w"
                sizes="(max-width: 768px) 100vw, 338px"
                decoding="async"
                loading="lazy"
                width="338"
                height="190"
                alt="${story.title}"
              />
            </div>
          </div>
          
          <div class="card-body px-6 pt-6">
            <h5 class="card-title display-2 text-start text-dark-100 fw-normal text-truncate-2">${story.title}</h5>
            <p class="card-text text-dark display-3 text-start text-truncate-2">
              ${story.seo_meta_description}
            </p>
          </div>
          
          <div class="card-footer bg-transparent border-0 px-6 pb-6">
            <a
              href="${story.url || '#'}"
              class="btn btn-secondary text-white w-100 d-flex align-items-center justify-content-center gap-2"
              data-location-type="body:news-section"
              data-function-type="navigation"
              data-format-type="button"
              data-link-type="internal"
              onclick="LinkTrackingClickEvent(this,'cta_click')"
            >Read Article <span class="material-symbols-outlined display-3">
arrow_outward
</span></a>
          </div>
        </div>
      </div>
    `;
  };

  const initializeSwiper = () => {
    const config = {
      slidesPerView: 1,
      spaceBetween: 24,
      navigation: {
        nextEl: '.news-swiper__nav  .swiper-button-next',
        prevEl: '.news-swiper__nav .swiper-button-prev',
      },
      pagination: {
        el: '.news-swiper__nav .swiper-pagination',
        clickable: true
        
      },
      breakpoints: {
        768: { slidesPerView: 2 },
        1200: { slidesPerView: 3 }
      }
    };

    if (swiper) {
      swiper.update();
    } else {
      swiper = new Swiper('.news-swiper', config);
    }
  };

  const displayNews = async (stories) => {
    if (!container) return;

    if (!stories.length) {
      container.innerHTML = '<div class="alert alert-info">No results found</div>';
      return;
    }

    const slidesHTML = await Promise.all(stories.map(createNewsSlide));
    container.innerHTML = slidesHTML.join('');

    initializeSwiper();
  };

  return { displayNews, initializeSwiper };
};

// Filter management
const createFilterManager = (displayNews) => {
  let filters = {
    filterType: '',
    filterValue: '',
    selectedDate: null
  };

  const setFilter = async (type, value) => {
    filters = { ...filters, filterType: type, filterValue: value };
    await updateResults();
  };

  const setDateFilter = async (selectedDate) => {
    if (!selectedDate) return;
    filters = { ...filters, filterType: 'date', selectedDate };
    await updateResults();
  };

  const updateResults = async () => {
    const {data, modelJumpedName} = await fetchNewsData(filters);
    console.log(data)
    await displayNews(data);
    const headerTitle = document.querySelector(".new-header");
    if(modelJumpedName)
    headerTitle.textContent = `News from ${modelJumpedName}`
  };

  const resetFilters = () => {
    filters = {
      filterType: '',
      filterValue: '',
      selectedDate: null
    };
    
    const datepicker = document.getElementById('news-filter-datepicker');
    if (datepicker && $(datepicker).datepicker) {
      $(datepicker).datepicker('clearDates');
    }

    document.querySelectorAll('.accordion-collapse.show').forEach(accordion => {
      new bootstrap.Collapse(accordion).hide();
    });
  };

  const initializeEventListeners = () => {
    const newestBtns = document.querySelectorAll('.newest-btn');
    const oldestBtns = document.querySelectorAll('.oldest-btn');
    const datepicker = document.getElementById('news-filter-datepicker');

  
      // newestBtns.forEach((b) =>{
      //   b.addEventListener('click', () => setFilter('most-recent', 'newest'));
      // })
      newestBtns.forEach((b) => {
        b.addEventListener('click', () => {
          // First, remove active class from all buttons
          newestBtns.forEach(btn => btn.classList.remove('bg-secondary-200'));
          newestBtns.forEach(btn => btn.classList.remove('text-white'));
          newestBtns.forEach(btn => btn.classList.remove('bg-light'));
          oldestBtns.forEach(btn => btn.classList.remove('bg-secondary-200'));
          oldestBtns.forEach(btn => btn.classList.remove('text-white'));
          oldestBtns.forEach(btn => btn.classList.add('bg-light'));
          
          // Add active class to the clicked button
          b.classList.add('bg-secondary-200');
          b.classList.add('text-white');
          
          // Call your filter function
          setFilter('most-recent', 'newest');
        });
      });
    
      // oldestBtns.forEach((b) =>{
      //   b.addEventListener('click', () => setFilter('oldest', 'oldest'));
      // })

      oldestBtns.forEach((b) => {
        b.addEventListener('click', () => {
          // First, remove active class from all buttons
          newestBtns.forEach(btn => btn.classList.remove('bg-secondary-200'));
          newestBtns.forEach(btn => btn.classList.remove('text-white'));
          newestBtns.forEach(btn => btn.classList.add('bg-light'));
          oldestBtns.forEach(btn => btn.classList.remove('bg-secondary-200'));
          oldestBtns.forEach(btn => btn.classList.remove('text-white'));
          oldestBtns.forEach(btn => btn.classList.remove('bg-light'));
          
          // Add active class to the clicked button
          b.classList.add('bg-secondary-200');
          b.classList.add('text-white');
          
          // Call your filter function
          setFilter('oldest', 'oldest');
        });
      });
  
    if (datepicker) {
      const picker = new Datepicker(datepicker, {
        format: 'MMMM yyyy',
        autohide: false,
        showDaysOfWeek: true,
        weekStart: 0,
        daysOfWeekHighlighted: [0, 6],
        todayHighlight: true,
        updateOnBlur: false,
        maxView: 1,
        defaultViewDate: '',
        prevArrow: '&lt;',
        nextArrow: '&gt;',
      });

      // picker.setDate(new Date());
      
      const today = new Date();
      picker.picker.element.querySelector('.today')?.classList.remove('today');
      const todayCell = Array.from(picker.picker.element.querySelectorAll('.datepicker-cell'))
        .find(cell => cell.dataset.date === today.toISOString().split('T')[0]);
      if (todayCell) todayCell.classList.add('today');

      datepicker.addEventListener('changeDate', (e) => {
        const selectedDate = e.detail.viewDate ? new Date(e.detail.viewDate) : null;
        setDateFilter(selectedDate);
      });
    }
  };

  return { setFilter, setDateFilter, resetFilters, initializeEventListeners };
};

// Category management
const createCategoryManager = (filterManager) => {
  const createCategoryItem = (service) => `
    <li>
      <button 
        class="category-filter__item list-group-item list-group-item-action bg-light rounded-2 mb-3 py-2 px-6 d-flex align-items-center"
        data-search-term="${service.title.toLowerCase()}"
        data-search-filter-type="category"
        data-value="${service.meta.zuid}"
        data-search-filter-value="${service.title.toLowerCase()}"
        onclick="handleCategoryClick(this)"
      >
        <span class="material-symbols-outlined me-2 text-primary-200">${service.icon_name || 'category'}</span>
        ${service.title}
      </button>
    </li>
  `;

  const updateCategories = async () => {
    try {
      const categoriesContainer = document.querySelector('#categories .accordion-body ul');
      if (!categoriesContainer) return;

      const response = await fetch(`https://{{instance.domain}}/service-types.json`);
      const serviceTypes = await response.json();
      
      if (!Array.isArray(serviceTypes) || !serviceTypes.length) return;

      categoriesContainer.innerHTML = serviceTypes.map(createCategoryItem).join('');
    } catch (error) {
      console.error('Error updating categories:', error);
    }
  };

  return { updateCategories };
};

function adjustPaginationBullets() {
    // const swiper = swiper;
    const maxVisibleBullets = 5;
    const totalBullets = swiper.pagination.bullets.length;
    const prevButton = document.querySelector(".news-swiper__nav .swiper-button-prev");
    const nextButton = document.querySelector(".news-swiper__nav .swiper-button-next");

    let start = Math.floor(swiper.activeIndex / maxVisibleBullets) * maxVisibleBullets;
    let end = start + maxVisibleBullets;

    if (end > totalBullets) {
      end = totalBullets;
      start = Math.max(0, end - maxVisibleBullets);
    }

    if (end - start < maxVisibleBullets && start > 0) {
      start = Math.max(0, end - maxVisibleBullets);
    }

    swiper.pagination.bullets.forEach((bullet, index) => {
        bullet.style.display = index >= start && index < end ? "inline-block" : "none";
    });

    const startEllipsis = document.querySelector('.pagination-start-ellipsis');
    if (start > 0) {
      if (!startEllipsis) {
          const bullet = document.createElement('span');
          bullet.className = 'pagination-start-ellipsis';
          bullet.textContent = '...';
          bullet.style.display = 'inline-block';
          bullet.style.marginRight = '-8px';
          swiper.pagination.bullets[start].parentNode.insertBefore(bullet, swiper.pagination.bullets[start]);
      }
    } else if (startEllipsis) {
      startEllipsis.remove();
    }

    const endEllipsis = document.querySelector('.pagination-ellipsis');
    if (end < totalBullets) {
      if (!endEllipsis) {
        const bullet = document.createElement('span');
        bullet.className = 'pagination-ellipsis';
        bullet.textContent = '...';
        bullet.style.display = 'inline-block';
        bullet.style.marginLeft = '-8px';
        swiper.pagination.bullets[end - 1].parentNode.appendChild(bullet);
      }
    } else if (endEllipsis) {
      endEllipsis.remove();
    }
    const totalSlides = swiper.slides.length; 
    const visibleSlides = swiper.params.slidesPerView; 

    const remainingSlides = totalSlides - swiper.activeIndex - visibleSlides; 

    toggleButtonState(nextButton, remainingSlides <= 0);
    toggleButtonState(prevButton, servicesSwiper.activeIndex === 0);
  }
function updateSwiperBulletsAttribute() {
   // Find all SwiperJS pagination bullet elements
  const paginationBullets = document.querySelectorAll('.swiper-pagination-bullet');
  
  // Optional: Handle dynamically added pagination bullets (e.g., after Swiper initialization)
  const observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
      if (mutation.addedNodes.length) {
        const newBullets = document.querySelectorAll('.news-swiper__nav .swiper-pagination-bullet:not([data-location-type])');
        
        newBullets.forEach((bullet, index) => {
          // Find the true index by counting preceding bullets
          const allBullets = document.querySelectorAll('.swiper-pagination-bullet');
          const trueIndex = Array.from(allBullets).indexOf(bullet);
          
          bullet.setAttribute('data-location-type', 'body:news');
          bullet.setAttribute('data-function-type', 'other');
          bullet.setAttribute('data-format-type', 'icon-block');
          bullet.setAttribute('data-page-componentType-type', 'news component');
          bullet.setAttribute('data-page-componentHeading-type', 'null');
          bullet.setAttribute('data-page-componentSubheading-type', 'null');
          bullet.setAttribute('data-page-componentIndex-type', `${trueIndex !== -1 ? trueIndex : index}`);
          bullet.setAttribute('onclick', "LinkTrackingClickEvent(this,'view_content_click')");
        });
        
        if (newBullets.length > 0) {
          console.log(`Analytics attributes added to ${newBullets.length} new SwiperJS pagination bullets`);
        }
      }
    });
  });
  
  // Start observing the document body for added pagination bullets
  observer.observe(document.body, { childList: true, subtree: true });
}
  function dateFormatter(date) {
  if (!date) return;

  const [year, month, day] = date.split('-');
  const monthNames = [
    'January',
    'February',
    'March',
    'April',
    'May',
    'June',
    'July',
    'August',
    'September',
    'October',
    'November',
    'December'
  ];

  const monthName = monthNames[parseInt(month, 10) - 1];
  return `${monthName} ${parseInt(day, 10)}, ${year}`;
}

// Initialize everything
document.addEventListener('DOMContentLoaded', () => {
  const {displayNews, initializeSwiper} = createNewsDisplay();
  initializeSwiper();
  updateSwiperBulletsAttribute();
  const filterManager = createFilterManager(displayNews);
  const categoryManager = createCategoryManager(filterManager);

  // Initialize filters and categories
  filterManager.initializeEventListeners();
  categoryManager.updateCategories();

  // Format date in author section
  const dateContainer = document.querySelector('.author-date');
  if (dateContainer) {
    dateContainer.textContent = dateFormatter(dateContainer.textContent);
  }

  // Initialize with default news items
  filterManager.setFilter('most-recent', null);

  adjustPaginationBullets();
  // Make filterManager available globally for category click handling
  window.filterManager = filterManager;
  adjustPaginationBullets();
});

// Global handler for category clicks
const handleCategoryClick = (button) => {
  window.filterManager.setFilter('category', button.getAttribute('data-value'));
};
</script>

<style>
  .news-swiper {
    height: auto;
  }
  .author-date {
    font-family: 'AJensonPro', sans-serif;
  }
</style>

<script>

  const mobileFilter = document.getElementById('mobileFilter');

 
      const filterTooltip = document.getElementById('filterTooltip');

        mobileFilter.addEventListener('click', function (e) {
        e.preventDefault();
        filterTooltip.style.display = filterTooltip.style.display === 'block' ? 'none' : 'block';
      });

      document.addEventListener('click', function (e) {
      if (!filterTooltip.contains(e.target) && e.target !== mobileFilter) {
        filterTooltip.style.display = 'none';
      }
    });
</script>
