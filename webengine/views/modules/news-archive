<script>

    // Initialize global variables
    let pageLimit = 15;
    let totalArticleCount = 0;
    let numberOfPages = 0;
    let stories = [];
    let searchResults = null;
    function buildParentNewsLink(truepath) {
        const parentNewsroomLinkContainer = document.querySelector("#parent-news__link");
        parentNewsroomLinkContainer.setAttribute('href', truepath +'stories');
    }

    function showLoader(container) {
        if (!container) return;
        container.innerHTML = `
            <div class="loader-container">
                <div class="loader-spinner">
                    <span class="material-symbols-outlined spin text-primary" style="font-size: 2rem;">progress_activity</span>
                </div>
                <div class="loader-text">Loading news articles...</div>
            </div>
        `;
    }

      function fixMalformedJSON(rawText) {
            try {
            // Remove line breaks and unnecessary whitespace
            let cleaned = rawText.replace(/\n/g, ' ').replace(/\s+/g, ' ');

            // Remove trailing commas before closing brackets
            cleaned = cleaned.replace(/,\s*]/g, ']');
            cleaned = cleaned.replace(/,\s*}/g, '}');

            // Remove empty lines or invalid commas between objects
            cleaned = cleaned.replace(/},\s*,\s*{/g, '}, {');

            // Try to parse it
            const json = JSON.parse(cleaned);
            return json;
            } catch (err) {
            console.error('Failed to parse JSON:', err.message);
            return null;
            }
  }

    async function getStories(params) {
        try {
            const response = await fetch(`https://{{instance.domain}}/stories.json?limit=0&show=15`);
            const stories = await response.json();
            
            return stories.data;
        } catch (error) {
            console.error('Error in getStories:', error);
            return [];
        }
    }


    
    async function fetchNews(searchTerm, filterType, filterValue, selectedDate, pageNumber = 1) {
        try {
            let url = `https://{{instance.domain}}/stories.json`;
            const params = new URLSearchParams();
            const locationZUID = cookieManager.get('location_zuid');
            const locationModel = cookieManager.get('location_model');
            
            // Calculate limit and show parameters based on pageNumber
            const limit = (pageNumber - 1) * pageLimit;
            const show = pageLimit;
            
            if (searchTerm) {
                params.append('name', searchTerm);
            }
            if (locationZUID && locationModel) {
                params.append('location', locationZUID);
                params.append('model', locationModel);
            }
            
            // Add parameters based on filter type
            if (filterType === 'most-recent') {
                params.append('most-recent', '1');
            } else if (filterType === 'category' && filterValue) {
                params.append('related-service', filterValue);
            } else if (filterType === 'date' && selectedDate) {
                const date = new Date(selectedDate);
                const formattedDate = `${date.getMonth() + 1}/${date.getDate()}/${date.getFullYear()}`;
                params.append('date', formattedDate);
            }
            
            // Add pagination parameters
            params.append('limit', limit.toString());
            params.append('show', show.toString());
            
            // Add params to URL if any exist
            if (params.toString()) {
                url += '?' + params.toString();
            }

            const response = await fetch(url);
            // const rawText = await response.text()
            // const fixedData = fixMalformedJSON(rawText);
            // if (!fixedData) {
            //     throw new Error('Invalid JSON format.');
            // }


            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            const { data, initialReturn, modelJumped, modelJumpedName, modelJumpedZuid, modelJumpedNewsroomUrl, totalItems } = await response.json();
            
            

            if (initialReturn !== 1) {
                let retArr = new Array();
                retArr['paretnData'] = data;
                retArr['modelJumped'] = modelJumped;
                retArr['modelJumpedName'] = modelJumpedName;
                retArr['initialReturn'] = initialReturn;
                retArr['modelJumpedZuid'] = modelJumpedZuid;
                retArr['modelJumpedNewsroomUrl'] = modelJumpedNewsroomUrl;
                retArr['data'] = [];
                totalArticleCount = 0;
                return Array.isArray(retArr) ? retArr : [retArr];
            } else {
                totalArticleCount = totalItems;
                return Array.isArray(data) ? data : [data];
            }
            
        } catch (error) {
            console.error('Error fetching news:', error);
            return [];
        }
    }

    async function getServiceTypes() {
        try {
            const response = await fetch(`https://{{instance.domain}}/service-types.json`);
            const serviceTypes = await response.json();
            return serviceTypes;
        } catch (error) {
            console.error('Error in getServiceTypes:', error);
            return [];
        }
    }

    async function getServiceType(zuid) {
        try {
            const response = await fetch(`https://{{instance.domain}}/service-types.json?zuid=${zuid}`);
            const serviceType = await response.json();
            const innerHTML = `
                <div
                class="d-flex align-items-center badge bg-white text-danger rounded-5 position-absolute top-3 start-3 px-4 py-2 z-3"
                >
                <i class="material-symbols-outlined me-2 text-primary-200 display-4">${serviceType[0].icon_name}</i>
                <span class="text-dark-100 display-4 fw-normal">${serviceType[0].title}</span>
                </div>
            `;
            return innerHTML;
        } catch (error) {
            console.error('Error in getServiceType:', error);
            return '';
        }
    }

    // Modified buildNewsList function to handle initialReturn = 1
async function buildNewsList(pageNumber, params, fetchData, newSearchResults = null) {

    
    const listContainer = document.querySelector('.news-archive-list');
    try {
        // Wait for DOM to be ready
        if (document.readyState === 'loading') {
            await new Promise(resolve => document.addEventListener('DOMContentLoaded', resolve));
        }

        // Ensure pageNumber is a valid number
        pageNumber = parseInt(pageNumber) || 1;

        if (!listContainer) {
            console.error('News archive list container not found');
            return;
        }

        // Show loader while fetching and processing data
        showLoader(listContainer);

        // For server-side pagination, we always need to fetch the data for the current page
        // We can no longer rely on previously fetched stories
        const searchForm = document.getElementById('newsSearchForm');
        const searchInput = document.getElementById('searchNews');
        const hiddenInput = document.getElementById('contentType');
        const selectedDateInput = document.getElementById('selectedDate');
        
        const searchTerm = searchInput ? searchInput.value.trim() : '';
        const filterType =  'most-recent';
        const filterValue = hiddenInput ? hiddenInput.getAttribute('data-zuid') : '';
        const selectedDate = selectedDateInput ? selectedDateInput.value : '';
        
        // Fetch data for the current page if new data wasn't provided
        const results = newSearchResults || await fetchNews(searchTerm, filterType, filterValue, selectedDate, pageNumber);
        
        // Handle case when no results are found
        if (totalArticleCount === 0) {
            listContainer.innerHTML = `
                <div class="text-center w-100 py-5">
                    <span class="material-symbols-outlined text-secondary mb-3" style="font-size: 3rem;">search_off</span>
                    <p class="text-secondary mb-0">No results found</p>
                </div>
            `;
            
            const resultCount = document.querySelector('#resultCount');
            const totalArticleCountElement = document.querySelector('#totalAticleCount');
            const paginationElement = document.querySelector(".swiper-pagination");
            
            if (resultCount) resultCount.innerHTML = '0';
            if (totalArticleCountElement) totalArticleCountElement.innerHTML = '0';
            if (paginationElement) paginationElement.innerHTML = '';
            return;
        }
        
        // Process stories for current page
        let processedStories = "";
        
        // Parse response based on the structure
        const stories = results['initialReturn'] == 0 ? results['data'] : results;
        stories.sort((a, b) => new Date(b.date) - new Date(a.date));
        // For each story in the current page, build the card
        for (let i = 0; i < stories.length; i++) {
            const story = stories[i];
            const serviceType = story.related_service ? await getServiceType(story.related_service.meta.zuid) : '';
            let storyImage = story.image ? story.image : resolveImages() ;
            if(window.innerWidth <= 768) {
            storyImage += "?width=396&height=222&crop=16:9,smart&quality=100";
            } else {
            storyImage += "?width=338&height=190&crop=16:9,smart&quality=100";
            }
            processedStories += `
                <div class="card me-2 mb-2 rounded-5 overflow-hidden" style="width: 31.9%; height:490px">
                    <div class="card-img-top card-img-top__large bg-secondary bg-opacity-25 position-relative overflow-hidden">
                 
                    <div
                        class="position-absolute bottom-4 start-0 d-flex align-items-center justify-content-between w-100 px-6 text-light display-4 z-3"
                    >
                        <span class="d-block">${dateFormatter(story.date)}</span>
                        <span class="d-block">${story.author ? `By ${story.author}` : '' }</span>
                    </div>
                    <div class="ratio ratio-16x9 h-100">
                    <img
                        class="img-fluid"
                        src="${storyImage}"
                        alt="${story.image ? story.image : 'Stories Image' }"
                        style="object-fit: cover;"
                    />
                    </div>
                    </div>
                    <div class="card-body px-6 pt-6">
                    <h5 class="card-title display-2 text-start text-dark-100 fw-normal">${story.title}</h5>
                    <div class="card-text text-dark display-3 text-start">
                        ${story.seo_meta_description}
                    </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 px-6 pb-6">
                    <a
                        href=${story.url}
                        class="btn btn-secondary text-white w-100"
                        data-link-url="${story.url}"
                        data-link-text="Read Article"
                        data-link-location="body:news-section"
                        data-function-type="navigation"
                        data-link-format="button"
                        data-link-type="internal"
                        onclick="newsSearchResultClickEvent(this)"
                        >Read Article</a
                    >
                    </div>
                </div>
            `;
        }

        // Update the list container
        listContainer.innerHTML = processedStories;

        // Check if initialReturn is 1, and handle pagination accordingly
        if (results['initialReturn'] == 1) {
            // Hide pagination elements when initialReturn is 1
            const paginationElement = document.querySelector(".swiper-pagination");
            const prevButton = document.querySelector(".swiper-button-prev");
            const nextButton = document.querySelector(".swiper-button-next");
            const resultCount = document.querySelector('#resultCount');
            const totalArticleCountElement = document.querySelector('#totalAticleCount');
            
            // Hide pagination
            if (paginationElement) paginationElement.innerHTML = '';
            if (prevButton) prevButton.style.display = 'none';
            if (nextButton) nextButton.style.display = 'none';
            
            // Update counts to show all items are displayed (no pagination)
            if (resultCount && totalArticleCountElement) {
                resultCount.innerHTML = stories.length;
                totalArticleCountElement.innerHTML = stories.length;
            }
            
            // Hide parent news section if it exists (since we're not using buildCardSlider)
            const parentContainer = document.querySelector('#parent-news');
            if (parentContainer && !parentContainer.classList.contains('d-none')) {
                parentContainer.classList.add('d-none');
            }
        } else {
            // Update counts and pagination for normal case (initialReturn is 0)
            const resultCount = document.querySelector('#resultCount');
            const totalArticleCountElement = document.querySelector('#totalAticleCount');
            const prevButton = document.querySelector(".swiper-button-prev");
            const nextButton = document.querySelector(".swiper-button-next");
            
            // Show navigation buttons
            if (prevButton) prevButton.style.display = '';
            if (nextButton) nextButton.style.display = '';

            if (resultCount && totalArticleCountElement) {
                let startCount = (pageNumber - 1) * pageLimit + 1;
                
                let endCount = pageNumber * pageLimit;
                if (endCount > totalArticleCount) endCount = totalArticleCount;
                
                resultCount.innerHTML = `${startCount}-${endCount}`;
                totalArticleCountElement.innerHTML = totalArticleCount;

                // Calculate number of pages and update pagination with ellipsis
                numberOfPages = Math.ceil(totalArticleCount / pageLimit);
                updatePaginationWithEllipsis(pageNumber);
            }
        }

        // Show search results container if it exists
        const searchResultsContainer = document.querySelector("#searchResults");
        if (searchResultsContainer) {
            searchResultsContainer.classList.remove("d-none");
        }
        
    } catch (error) {
        console.error('Error in buildNewsList:', error);
        if (listContainer) {
            listContainer.innerHTML = `
                <div class="text-center w-100 py-5">
                    <span class="material-symbols-outlined text-danger mb-3" style="font-size: 3rem;">error</span>
                    <p class="text-danger mb-0">Error loading news articles. Please try again later.</p>
                </div>
            `;
        }
    }
}

    async function populateCategoryOptions() {
        const categoryOptions = document.getElementById('categoryOptions');
        if (!categoryOptions) return;

        const serviceTypes = await getServiceTypes();
        
        if (serviceTypes && Array.isArray(serviceTypes)) {
            const optionsHTML = serviceTypes.map(service => `
                <div class="option child-option d-flex align-items-center" data-value="${service.meta.zuid}" data-zuid="${service.meta.zuid}">
                    <span class="material-symbols-outlined text-primary-200 me-3">
                        ${service.icon_name}
                    </span>
                    <span>${service.title}</span>
                </div>
            `).join('');
            categoryOptions.innerHTML = optionsHTML;

            // Reattach event listeners to new options
            categoryOptions.querySelectorAll('.child-option').forEach(option => {
                option.addEventListener('click', async function(e) {
                    e.stopPropagation();
                    
                    const selectedText = document.querySelector('.selected-text');
                    const hiddenInput = document.getElementById('contentType');
                    const customSelect = document.querySelector('.custom-select-trigger');
                    const customOptions = document.querySelector('.custom-options');
                    
                    if (selectedText && hiddenInput && customSelect && customOptions) {
                        // Update selected text and hidden input
                        selectedText.textContent = this.querySelector('span:last-child').textContent; // Changed to get only the title text
                        hiddenInput.value = 'category';
                        hiddenInput.setAttribute('data-zuid', this.dataset.zuid);
                        
                        // Remove selected class from all child options
                        document.querySelectorAll('.child-option').forEach(opt => opt.classList.remove('selected'));
                        // Add selected class to clicked option
                        this.classList.add('selected');
                        
                        // Close dropdown
                        customSelect.classList.remove('open');
                        customOptions.classList.remove('open');
                        customSelect.setAttribute('aria-expanded', 'false');
                        
                        // Hide all child options
                        document.querySelectorAll('.child-options').forEach(opt => {
                            opt.style.display = 'none';
                        });

                        // Fetch and display results
                        const results = await fetchNews('', 'category', this.dataset.zuid, '');
                        if (results['initialReturn'] == 0) {
                            const parentContainer = document.querySelector('#parent-news');
                            const parentHeading = document.querySelector('.parent-news__heading');
                            const modelJumped = results['modelJumped'];
                            const model = modelJumped.charAt(0).toUpperCase() + modelJumped.slice(1);
                            if (parentContainer.classList.contains('d-none')) {
                                parentContainer.classList.remove('d-none');
                            }
                            if(modelJumped == 'territory') {
                                parentHeading.textContent = `More stories from ${results['modelJumpedName']}`
                            } else {
                                parentHeading.textContent = `More stories from ${results['modelJumpedName']} ${model}`
                            }
                            buildCardSlider(results['paretnData']);
                            buildNewsList(1, "", false, results['data']);
                        } else {
                            buildNewsList(1, "", false, results);
                        }
                    }
                });
            });
        }
    }

