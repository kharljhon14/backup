    mutations.forEach(function(mutation) {
      if (mutation.addedNodes.length) {
        const newBullets = document.querySelectorAll('.swiper-pagination-bullet:not([data-location-type])');
        const nextButton = document.querySelector('.next-stories-button');
        const prevButton = document.querySelector('.prev-stories-button');
        
