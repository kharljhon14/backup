        prevButton.setAttribute('data-news-search-filter-type', '');
        prevButton.setAttribute('data-news-search-filter-value', '');
        prevButton.setAttribute('data-news-link-function', 'other');
        prevButton.setAttribute('data-news-link-format', 'button');
        prevButton.setAttribute('onclick', "newsSearchViewMoreEvent(this)");
        
        newBullets.forEach((bullet, index) => {
          // Find the true index by counting preceding bullets
          const allBullets = document.querySelectorAll('.swiper-pagination-bullet');
          const trueIndex = Array.from(allBullets).indexOf(bullet);
          
          bullet.setAttribute('data-news-search-term', searchInput.value);
          bullet.setAttribute('data-news-search-filter-type', '');
          bullet.setAttribute('data-news-search-filter-value', '');
          bullet.setAttribute('data-news-link-function', 'other');
          bullet.setAttribute('data-news-link-format', 'button');
          bullet.setAttribute('onclick', "newsSearchViewMoreEvent(this)");
        });

      }
    });
  });
  
  // Start observing the document body for added pagination bullets
  observer.observe(document.body, { childList: true, subtree: true });
}

