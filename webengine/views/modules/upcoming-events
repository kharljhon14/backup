    </div>
    </div>
  </div>
  <div class="events-swiper__nav d-flex w-100 justify-content-end align-items-center mt-5">
    <div
      class="swiper-button-prev position-relative {{if {$page_type_detail} != "events_landing_pages" }} bg-area {{else}}bg-light {{/if}} bg-opacity-60 me-4"
