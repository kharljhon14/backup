    </div>

    <div
      class="swiper-pagination events-pagination {{if {$page_type_detail} != "events_landing_pages" }} bg-area {{/if}} position-relative px-4 rounded-14"
      data-location-type="body:events"
      data-function-type="other"
      data-format-type="icon-block"
      data-page-componentType-type="events component"
      data-page-componentHeading-type="null"
      data-page-componentSubheading-type="null"
      data-page-componentIndex-type="null"
      onclick="LinkTrackingClickEvent(this,'view_content_click')"
    ></div>

    <div
      class="swiper-button-next {{if {$page_type_detail} != "events_landing_pages" }} bg-area {{else}}bg-light {{/if}} position-relative bg-opacity-60  ms-4"
      data-location-type="body:events"
      data-function-type="other"
      data-format-type="icon-block"
      data-page-componentType-type="events component"
      data-page-componentHeading-type="null"
      data-page-componentSubheading-type="null"
      data-page-componentIndex-type="null"
