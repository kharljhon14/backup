<div class="mt-16">
  <!-- <h1 class="fs-4 ms-8 mb-6">Searh Results for "Z5005":</h1> -->
  <div class="bg-light p-8 rounded-5 align-items-center gap-4">
    <div class="row g-3">
      {{each locations as location sort by name ASC where find_in_set('{page.zuid}', city )}}
      <div class="col-12 col-md-4 col-lg-3">
        <div class="bg-area p-6 rounded-5 h-100">
          <a
            class="text-secondary city-card-name"
            href="{{truepath({location.zuid})}} "
            >{{ location.name }}</a
          >
          <p class="m-0 text-dark-50 text-capitalize">{{ location.address }}</p>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</div>

<script>
  const cityCardNames = document.querySelectorAll('.city-card-name');
  const regex = /\b(?!\b(?:a|an|the|and|but|or|nor|for|so|yet|as|at|by|in|of|off|on|per|to|up|from|into|onto|over|with)\b)([A-Za-z0-9\u00C0-\u017F]+(?:['-][A-Za-z0-9\u00C0-\u017F]+)*)\b/gi;

  cityCardNames.forEach((cityCardName) => {
    const result = cityCardName.textContent.replace(regex, (word) => {
      return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
    });

    cityCardName.textContent = result;
  });
</script>
