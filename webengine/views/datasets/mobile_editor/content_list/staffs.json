{{$skip = 0 }}
{{$limit = 20 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}


{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = first_name }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{else}}
{{$property = "" }}
{{end-if}}

{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{else}}
{{$division = "" }}
{{end-if}}

{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{else}}
{{$territory = "" }}
{{end-if}}



{
    "data": [
        {{each staffs as staffUser WHERE find_in_set({$property}, member_locations) AND CONCAT(first_name, ' ', last_name) LIKE {$search} OR find_in_set({$division}, member_divisions) AND CONCAT(first_name, ' ', last_name) LIKE {$search} OR find_in_set({$territory}, member_territories) AND CONCAT(first_name, ' ', last_name) LIKE {$search} LIMIT {$skip}, {$limit} SORT BY staffUser.{$sort_by} {$sort_order} }}
        {{$totalItems = {staffUser._num} }}
        {
            "data": {
                "title": "{{staffUser.first_name}} {{staffUser.last_name}}",
                "description": "Last modified {{staffUser.updated_at.date(m/d/Y)}}",
                "image": "{{staffUser.profile}}",
                "property":  "{{staffUser.member_locations}}"
            },
            "meta": {
                "ZUID": "{{staffUser.zuid}}",
                "masterZuid": "{{staffUser.zuid}}",
                "contentModelZuid": "{{staffUser.set_zuid}}"
            }
        }{{staffUser._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}