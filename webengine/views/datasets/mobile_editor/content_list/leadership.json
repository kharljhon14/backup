{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "%%" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}
{{$queryFilter = llp.title LIKE {$search} AND llp.location IS NULL AND llp.division IS NULL AND llp.territory IS NULL AND national = 1 }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}

{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{$queryFilter = llp.title LIKE {$search} AND llp.location = {$property} }}
{{else}}
{{$property = "" }}
{{end-if}}

{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{$queryFilter = llp.title LIKE {$search} AND llp.division = {$division} AND llp.location IS NULL}}
{{else}}
{{$division = "" }}
{{end-if}}


{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{$queryFilter = llp.title LIKE {$search} AND llp.territory = {$territory} AND llp.location IS NULL AND llp.division IS NULL}}
{{else}}
{{$territory = "" }}
{{end-if}}



{
    "data": [
      
            {{each leadership_landing_page as llp WHERE {$queryFilter} LIMIT {$skip}, {$limit} SORT BY llp.{$sort_by} {$sort_order} }}
            {{$totalItems = {llp._num} }}         
                {
                "data": {
                    "title": "{{llp.title.escapeForJs()}}",
                    "description": "Last modified {{event.updated_at.date(m/d/Y)}}",
                    "image": "{{llp.hero_image}}",
                    "property":  "{{llp.location)}}",
                    "division": "{{llp.division}}",
                    "url_path": "{{llp.getUrl()}}"
                    },
                "meta": {
                    "ZUID": "{{llp.zuid}}",
                    "masterZuid": "{{llp.zuid}}",
                    "contentModelZuid": "{{llp.set_zuid}}",
                    "meta_title": "{{cu.seo_meta_title.escapeForJs()}}"
                    }
                 } {{event._arraycomma}}
            
            {{/each}}

      
         
           
     
    ],
  
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}