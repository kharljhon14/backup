{{$skip = 0 }}
{{$limit = 20 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "" }}
{{$territory = "" }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}


{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = name }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{else}}
{{$territory = "" }}
{{end-if}}


{{each locations as location WHERE location.zuid = {$property} }}
{{$totalItems = {location._num} }}
{{/each}}

{
    "data": [
        {{each territories as territory WHERE territory.zuid = {$territory} AND territory.name LIKE {$search} LIMIT {$skip}, {$limit} SORT BY territory.{$sort_by} {$sort_order} }}
        {
            "data": {
                "title": "{{territory.name.escapeForJs()}}",
                "description": "Last modified {{territory.updated_at.date(m/d/Y)}}",
                "image": "{{territory.og_image}}",
                "property":  "{{territory.zuid}}"
            },
            "meta": {
                "ZUID": "{{territory.zuid}}",
                "masterZuid": "{{territory.zuid}}",
                "contentModelZuid": "{{territory.set_zuid}}"
            }
        } {{territory._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$territory}}
    }
}