{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "%%" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}
{{$queryFilter = cu.title LIKE {$search} AND cu.location IS NULL AND cu.division IS NULL AND cu.territory IS NULL AND national = 1}}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}

{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{$queryFilter = cu.title LIKE {$search} AND cu.location = {$property} }}
{{else}}
{{$property = "" }}
{{end-if}}

{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{$queryFilter = cu.title LIKE {$search} AND cu.division = {$division} }}
{{else}}
{{$division = "" }}
{{end-if}}

{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{$queryFilter = cu.title LIKE {$search} AND cu.territory = {$territory} }}
{{else}}
{{$territory = "" }}
{{end-if}}


{
    "data": [
        {{each contact_us as cu WHERE {$queryFilter} LIMIT {$skip}, {$limit} SORT BY cu.{$sort_by} {$sort_order} }}
        {{$totalItems = {cu._num} }}
        {
            "data": {
                "title": "{{cu.title.escapeForJs()}}",
                "description": "Last modified {{event.updated_at.date(m/d/Y)}}",
                "image": "{{cu.hero_image}}",
                "property":  "{{cu.location}}",
                "url_path": "{{cu.getUrl()}}"
                },
            "meta": {
                "ZUID": "{{cu.zuid}}",
                "masterZuid": "{{cu.zuid}}",
                "contentModelZuid": "{{cu.set_zuid}}",
                "meta_title": "{{cu.seo_meta_title.escapeForJs()}}"
                }
        } {{event._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}