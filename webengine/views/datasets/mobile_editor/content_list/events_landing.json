{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "%%" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}
{{$queryFilter = elp.title LIKE {$search} AND elp.location IS NULL AND elp.division AND elp.territory IS NULL AND national = 1}}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}

{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{$queryFilter = elp.title LIKE {$search} AND elp.location = {$property} AND elp.division IS NOT NULL AND elp.territory IS NOT NULL  }}
{{else}}
{{$property = "" }}
{{end-if}}

{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{$queryFilter = elp.title LIKE {$search} AND elp.division = {$division} AND elp.location IS NULL AND elp.territory IS NOT NULL }}
{{else}}
{{$division = "" }}
{{end-if}}

{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{$queryFilter = elp.title LIKE {$search} AND elp.territory = {$territory} AND elp.location IS NULL AND elp.division IS NULL  }}
{{else}}
{{$territory = "" }}
{{end-if}}


{
    "data": [
        {{each events_landing_pages as elp WHERE {$queryFilter} LIMIT {$skip}, {$limit} SORT BY elp.{$sort_by} {$sort_order} }}
        {{$totalItems = {elp._num} }}
        {
            "data": {
                "title": "{{elp.title.escapeForJs()}}",
                "property":  "{{elp.location}}",
                "url_path": "{{elp.getUrl()}}"
                },
            "meta": {
                "ZUID": "{{elp.zuid}}",
                "masterZuid": "{{elp.zuid}}",
                "contentModelZuid": "{{elp.set_zuid}}"
                }
        } {{elp._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}