{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}



{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}

{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{$queryFilter = 'find_in_set({$property}, property)' }}
{{else}}
{{$property = "" }}
{{end-if}}

{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{$queryFilter = 'find_in_set({$division}, divisions)' }}
{{else}}
{{$division = "" }}
{{end-if}}


{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{$queryFilter = 'find_in_set({$division}, divisions)' }}
{{else}}
{{$territory = "" }}
{{end-if}}



{
    "data": [
        {{each events as event WHERE event.title LIKE {$search} AND find_in_set({$property}, property) OR event.title LIKE {$search} AND find_in_set({$division}, divisions) OR event.title LIKE {$search} AND find_in_set({$territory}, territories) LIMIT {$skip}, {$limit} SORT BY event.{$sort_by} {$sort_order} }}
        {{$totalItems = {event._num} }}
        {
            "data": {
                "title": "{{event.title.escapeForJs()}}",
                "description": "Last modified {{event.updated_at.date(m/d/Y)}}",
                "image": "{{event.image}}",
                "property":  "{{event.property}}",
                "url_path": "{{event.getUrl()}}"
                },
            "meta": {
                "ZUID": "{{event.zuid}}",
                "masterZuid": "{{event.zuid}}",
                "contentModelZuid": "{{event.set_zuid}}"
                }
        } {{event._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}