{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "" }}
{{$property = "" }}
{{$division = "" }}
{{$territory = "" }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}


{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{else}}
{{$property = "" }}
{{end-if}}


{{if {request.queryParam(division)} }}
{{$division = "{request.queryParam(division)}" }}
{{else}}
{{$division = "" }}
{{end-if}}


{{if {request.queryParam(territory)} }}
{{$territory = "{request.queryParam(territory)}" }}
{{else}}
{{$territory = "" }}
{{end-if}}



{
    "data": [
         {{each stories as story WHERE story.title LIKE {$search} AND find_in_set({$property}, property) OR story.title LIKE {$search} AND find_in_set({$division}, divisions) OR story.title LIKE {$search} AND find_in_set({$territory}, territory) LIMIT {$skip}, {$limit} SORT BY story.{$sort_by} {$sort_order} }}
        {{$totalItems = {story._num} }}
        {
            "data": {
                "title": "{{story.title.escapeForJs()}}",
                "description": "Last modified {{story.updated_at.date(m/d/Y)}}",
                "image": "{{story.story_image}}",
                "property":  "{{story.property}}",
                "url_path": "{{story.getUrl()}}"
            },
            "meta": {
                "ZUID": "{{story.zuid}}",
                "masterZuid": "{{story.zuid}}",
                "contentModelZuid": "{{story.set_zuid}}"
            }
        }{{story._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}},
        "division": {{$division}},
        "territory": {{$territory}}
    }
}