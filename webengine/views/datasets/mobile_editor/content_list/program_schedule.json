{{$skip = 0 }}
{{$limit = 0 }}
{{$totalItems = 0}}
{{$sort_order = desc}}
{{$sort_by = updated_at}}
{{$search = "" }}
{{$property = "" }}


{{if {request.queryParam(skip)} }}
{{$skip = {request.queryParam(skip)} }}
{{else}}
{{$skip = 0}}
{{end-if}}


{{if {request.queryParam(limit)} }}
{{$limit = {request.queryParam(limit)} }}
{{else}}
{{$limit = 10}}
{{end-if}}

{{if {request.queryParam(sort_order)} &&  {request.queryParam(sort_order)} === 'asc'}}
{{$sort_order = asc }}
{{else}}
{{$sort_order = desc }}
{{end-if}}

{{if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'name'}}
{{$sort_by = title }}
{{else if {request.queryParam(sort_by)} &&  {request.queryParam(sort_by)} === 'date'}}
{{$sort_by = updated_at }}
{{else}}
{{$sort_by = updated_at }}
{{end-if}}


{{if {request.queryParam(search)} }}
{{$search = "%{request.queryParam(search)}%" }}
{{else}}
{{$search = "%%" }}
{{end-if}}

{{if {request.queryParam(property)} }}
{{$property = "{request.queryParam(property)}" }}
{{else}}
{{$property = "" }}
{{end-if}}


{{each program_schedule as ps WHERE ps.location = {$property} }}
{{$totalItems = {ps._num} }}
{{/each}}

{
    "data": [
        {{each program_schedule as ps WHERE ps.title LIKE {$search} AND ps.location = {$property} LIMIT {$skip}, {$limit} SORT BY ps.{$sort_by} {$sort_order} }}
        {
            "data": {
                "title": "{{ps.title}}",
                "description": "Last modified {{event.updated_at.date(m/d/Y)}}",
                "image": null,
                "property":  "{{ps.location}}",
                "url_path": "{{ps.getUrl()}}"
                },
            "meta": {
                "ZUID": "{{ps.zuid}}",
                "masterZuid": "{{ps.zuid}}",
                "contentModelZuid": "{{ps.set_zuid}}"
                }
        } {{event._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "skip": {{$skip}},
        "limit": {{$limit}},
        "page": {{math({$skip} / {$limit} + 1)}},
        "pages": {{ math(ceil({$totalItems} / {$limit})) }},
        "totalItems": {{$totalItems}},
        "sortOrder": "{{$sort_order}}",
        "sortBy": "{{$sort_by}}",
        "search": {{$search}},
        "property": {{$property}}
    }
}