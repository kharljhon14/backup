{{$queryFilter}}


{{if {request.queryParam(division_zuid)} }}
    {{$queryFilter = division.zuid = "{request.queryParam(division_zuid)}" }}
{{end-if}}

{
   "data": [
        {{ each divisions as division WHERE {$queryFilter} }}
            {
                "value": "{{division.zuid}}",
                "label": "{{division.name.escapeForJs()}}",
                "locations": [
                     {{each locations as location WHERE location.division = '{division.zuid}' }}
                        {
                            "value": "{{location.zuid}}",
                            "label": "{{location.name.escapeForJs()}}",
                            "address": "{{location.address.escapeForJs()}}",
                            "parent_division": "{{location.division}}",
                            "model_zuid": "{{location.set_zuid}}"
                        } {{location._arraycomma}}
                     {{/each}}
                ] 
            } {{division._arraycomma}}
        {{/each}} 
   ]
}