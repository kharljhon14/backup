{{$property = {request.queryParam(property)} }}
{{$totalItems = 0}}


{{$division = {request.queryParam(division)} }}
{{$territory = {request.queryParam(territory)} }}




{
    "data": [
        {{each matrix_hero_sliders as heroSliders WHERE find_in_set('{$property}', display_on_locations) OR find_in_set('{$division}', display_on_divisions) OR find_in_set('{$territory}', display_on_territories) }}
        {{$totalItems = {heroSliders._num} }}
       
        {
            "data": {{matrix_hero_sliders.toJSON(1, true)}},
            "meta": {
                "ZUID": "{{heroSliders.zuid}}",
                "masterZuid": "{{heroSliders.zuid}}",
                "contentModelZuid": "{{heroSliders.set_zuid}}"
                
            }
        }{{heroSliders._arraycomma}}
        {{/each}}
    ],
    "_meta": {
        "totalItems": {{$totalItems}},
        "property": "{{$property}}",
        "contentModelZuid": "6-d4c0fbbee5-8j61c9"
    }
}