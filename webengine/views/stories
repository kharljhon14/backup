<script>
  async function  getLocation(zuid) {
    try {
      const response = await fetch(`${window.location.origin}/location-finder.json?query=${zuid}`);
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      const rawData = await response.text(); 
      const data = JSON.parse(rawData);
      return data.name;
    } catch (error) {
      console.error('Error checking location:', error);
      return false;
    }
  }

  const locationNameCookie = getCookieByName('location_name');
  const returnToNewsRoom = document.querySelector(".return-to-newsroom");

  if (locationNameCookie == 'NATIONAL') {
    returnToNewsRoom.setAttribute("href", "/stories")

  }else{
    returnToNewsRoom.setAttribute("href", getCookieByName("location_home_url")+"stories")
  }

  document.addEventListener("DOMContentLoaded", async function () {
    const articleDate = "{{!this.story_date_picker.date(F j, Y)}}";
    document.querySelector('.story__date').textContent = articleDate;
  }); 

  const cityCardNames = document.querySelectorAll('.location-name');
  const regex = /\b(?!\b(?:a|an|the|and|but|or|nor|for|so|yet|as|at|by|in|of|off|on|per|to|up|from|into|onto|over|with)\b)([A-Za-z0-9\u00C0-\u017F]+(?:['-][A-Za-z0-9\u00C0-\u017F]+)*)\b/gi;

  cityCardNames.forEach((cityCardName) => {
    const result = cityCardName.textContent.replace(regex, (word) => {
      return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
    });

    cityCardName.textContent = result;
  });


</script>